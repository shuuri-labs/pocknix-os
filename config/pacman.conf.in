# pocknix-os pacman.conf — Arch Linux ARM base (always valid).
#
# This file is the ALARM-only base, copied into the rootfs by build-image.sh.
# The holo repo (steam/gamescope) and the local pocknix repo are appended later,
# only when their packages are actually installed (Phase 3+), so the Phase 0 base
# install never trips over an unwired/unreachable repo. ALARM repos resolve via
# the mirrorlist the ALARM rootfs already ships in /etc/pacman.d/mirrorlist.

[options]
Architecture = aarch64
HoldPkg     = pacman glibc
CheckSpace
SigLevel    = Required DatabaseOptional
LocalFileSigLevel = Optional
ParallelDownloads = 5

[core]
Include = /etc/pacman.d/mirrorlist

[extra]
Include = /etc/pacman.d/mirrorlist

[alarm]
Include = /etc/pacman.d/mirrorlist

[aur]
Include = /etc/pacman.d/mirrorlist
