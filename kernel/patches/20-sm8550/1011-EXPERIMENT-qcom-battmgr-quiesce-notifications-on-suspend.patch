EXPERIMENT (pocknix, TEMPORARY): try to stop the ADSP charger firmware's
BATTMGR_NOTIFICATION (opcode 0x7) from waking the AP during deep suspend.

Confirmed via the 1010 logging patch that 0x7 is the wake message; it rings the
IRQF_NO_SUSPEND IPCC mailbox, which cannot be masked. So quiesce it at the source:
add system-sleep PM ops to qcom_battmgr that, on SM8550, re-issue
BATTMGR_REQUEST_NOTIFICATION with a capacity window of [0,100] on suspend -- the bet
being the firmware then only notifies OUTSIDE 0-100% capacity, i.e. never -- and
restore the default all-zero subscription on resume. Undocumented firmware semantics:
may or may not work. Also logs the notification SUBTYPE so we learn what 0x7 is either
way. If it doesn't stop the 0x7, fall back to userspace auto-resuspend. Remove once
resolved. See docs/sm8550-suspend-wake-report.md (Layer 3).
---
 drivers/power/supply/qcom_battmgr.c | 49 +++++++++++++++++++++++++++++
 1 file changed, 49 insertions(+)

--- a/drivers/power/supply/qcom_battmgr.c
+++ b/drivers/power/supply/qcom_battmgr.c
@@ -1202,4 +1202,5 @@ static void qcom_battmgr_notification(struct qcom_battmgr *battmgr,
 	notification = le32_to_cpu(msg->notification);
 	notification &= 0xff;
+	dev_info(battmgr->dev, "pocknix-wakedbg: notification subtype %#x\n", notification);
 	switch (notification) {
 	case NOTIF_BAT_INFO:
@@ -1641,3 +1642,4 @@ static int qcom_battmgr_probe(struct auxiliary_device *adev,
 	battmgr->dev = dev;
+	auxiliary_set_drvdata(adev, battmgr);
 
 	psy_cfg.drv_data = battmgr;
@@ -1727,8 +1729,52 @@ static int qcom_battmgr_probe(struct auxiliary_device *adev,
 	pmic_glink_client_register(battmgr->client);
 
 	return 0;
 }
 
+/* pocknix EXPERIMENT (temp): quiesce the ADSP BATTMGR_NOTIFICATION (0x7) that wakes us from
+ * deep suspend via the un-maskable IPCC line. Re-subscribe with a [0,100] capacity window on
+ * suspend (bet: firmware then notifies only OUTSIDE 0-100% = never); restore on resume. */
+static int __maybe_unused
+qcom_battmgr_set_notif(struct qcom_battmgr *battmgr, u32 low_cap, u32 high_cap)
+{
+	struct qcom_battmgr_enable_request req = {
+		.hdr.owner = cpu_to_le32(PMIC_GLINK_OWNER_BATTMGR),
+		.hdr.type = cpu_to_le32(PMIC_GLINK_NOTIFY),
+		.hdr.opcode = cpu_to_le32(BATTMGR_REQUEST_NOTIFICATION),
+		.low_capacity = cpu_to_le32(low_cap),
+		.high_capacity = cpu_to_le32(high_cap),
+	};
+	int ret;
+
+	mutex_lock(&battmgr->lock);
+	ret = qcom_battmgr_request(battmgr, &req, sizeof(req));
+	mutex_unlock(&battmgr->lock);
+	if (ret)
+		dev_warn(battmgr->dev, "pocknix: set-notif [%u,%u] failed: %d\n",
+			 low_cap, high_cap, ret);
+	return ret;
+}
+
+static int __maybe_unused qcom_battmgr_suspend(struct device *dev)
+{
+	struct qcom_battmgr *battmgr = dev_get_drvdata(dev);
+
+	if (battmgr && battmgr->variant == QCOM_BATTMGR_SM8550)
+		qcom_battmgr_set_notif(battmgr, 0, 100);
+	return 0;
+}
+
+static int __maybe_unused qcom_battmgr_resume(struct device *dev)
+{
+	struct qcom_battmgr *battmgr = dev_get_drvdata(dev);
+
+	if (battmgr && battmgr->variant == QCOM_BATTMGR_SM8550)
+		qcom_battmgr_set_notif(battmgr, 0, 0);
+	return 0;
+}
+
+static SIMPLE_DEV_PM_OPS(qcom_battmgr_pm_ops, qcom_battmgr_suspend, qcom_battmgr_resume);
+
 static const struct auxiliary_device_id qcom_battmgr_id_table[] = {
 	{ .name = "pmic_glink.power-supply", },
 	{},
@@ -1738,7 +1784,10 @@ MODULE_DEVICE_TABLE(auxiliary, qcom_battmgr_id_table);
 static struct auxiliary_driver qcom_battmgr_driver = {
 	.name = "pmic_glink_power_supply",
 	.probe = qcom_battmgr_probe,
 	.id_table = qcom_battmgr_id_table,
+	.driver = {
+		.pm = &qcom_battmgr_pm_ops,
+	},
 };
 
 module_auxiliary_driver(qcom_battmgr_driver);
