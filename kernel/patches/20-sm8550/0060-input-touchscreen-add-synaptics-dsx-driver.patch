 .../input/touchscreen/synaptics_dsx/Makefile  |    2 +
 .../synaptics_dsx/synaptics_dsx_core.c        | 1956 +++++++++++++++++
 .../synaptics_dsx/synaptics_dsx_core.h        |  299 +++
 .../synaptics_dsx/synaptics_dsx_i2c.c         |  453 ++++
 include/linux/input/synaptics_dsx.h           |   64 +
