@@ -245,6 +265,18 @@
 	bitmap_xor(&changes, &current_states, &prev_states, ARRAY_SIZE(keymap));
 
 	for_each_set_bit(i, &changes, ARRAY_SIZE(keymap)) {
+		if (keymap[i] == BTN_MODE && home_pulse_stretch_ms > 0) {
