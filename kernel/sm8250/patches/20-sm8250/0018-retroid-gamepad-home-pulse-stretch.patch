+static void gamepad_mode_release_work(struct work_struct *work)
+{
+	struct gamepad_device *dev = container_of(work, struct gamepad_device,
+						  mode_release_work.work);
+
+	input_report_key(dev->dev_input, BTN_MODE, 0);
+	input_sync(dev->dev_input);
+}
