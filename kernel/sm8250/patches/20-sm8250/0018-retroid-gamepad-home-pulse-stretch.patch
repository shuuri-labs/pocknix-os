 static bool rumble_enable = true;
 module_param(rumble_enable, bool, 0660);
 
+/*
+ * The MCU firmware never reports the home button's real state: it emits a
+ * fixed ~150ms BTN_MODE pulse regardless of how long the button is held.
+ * Stretch the reported press to this long so userspace chords (Guide+A)
+ * get a usable window. 0 disables the stretch.
+ */
+static int home_pulse_stretch_ms = 400;
+module_param(home_pulse_stretch_ms, int, 0660);
+
