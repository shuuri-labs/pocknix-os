# pocknix-bsp — board support for the Retroid Pocket 6 (SM8550).
# Carries device-specific quirks: suspend sleep.d runner + SDAM breadcrumb, and the
# InputPlumber composite-device config for the RP6 gamepad. Grows with audio/thermal.
pkgname=pocknix-bsp
pkgver=0.1.0
pkgrel=14
pkgdesc="pocknix board support (RP6/SM8550): suspend hooks, SDAM breadcrumb, InputPlumber + audio UCM"
arch=('any')
url="https://github.com/shuuri-labs/pocknix-os"
license=('GPL2')
depends=()
optdepends=('inputplumber: gamepad -> Steam Input mapping (uses 01-rsinput-rp6.yaml)'
            'alsa-ucm-conf: base UCM (codec include sequences for the AYN-Odin2 UCM)')
# NOTE: the spurious deep-sleep wake is FIXED in the kernel — kernel/patches/20-sm8550/
# 0504-wakeup-qcom-ipcc-remove-IRQF-NO-SUSPEND.patch (ported from ROCKNIX's SM8750/Odin 3)
# masks the IPCC mailbox during suspend so the ADSP charger firmware can't wake the SoC.
# That superseded the old battery-wake + auto-resuspend workarounds, now removed. See
# docs/sm8550-suspend-wake-report.md.
source=('pocknix-sleep' 'sdam-debug-pre' 'sdam-debug-post'
        'inputplumber-sleep-pre' 'inputplumber-sleep-post' '10-pocknix-deeponly.conf'
        '20-pocknix-powerkey.conf' '30-pocknix-cpuidle.conf'
        '01-rsinput-rp6.yaml'
        'rp6-gamepad.yaml' '90-pocknix-backlight.rules' '60-pocknix-controllers.rules'
        'AYN-Odin2.conf' 'HiFi.conf')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
            'SKIP' 'SKIP' 'SKIP')

package() {
  # systemd system-sleep hook that dispatches our sleep.d/{pre,post} scripts
  install -Dm755 "${srcdir}/pocknix-sleep" \
    "${pkgdir}/usr/lib/systemd/system-sleep/pocknix-sleep"

  # suspend/resume hooks (run by the hook above, in name order)
  # 001-inputplumber: drop the USB/IP virtual controller before sleep so vhci_hcd
  # doesn't veto suspend (the `deck` target attaches over USB/IP); restore on resume.
  install -Dm755 "${srcdir}/inputplumber-sleep-pre" \
    "${pkgdir}/usr/lib/pocknix/sleep.d/pre/001-inputplumber"
  install -Dm755 "${srcdir}/inputplumber-sleep-post" \
    "${pkgdir}/usr/lib/pocknix/sleep.d/post/001-inputplumber"
  # (002-battery-wake + 004-auto-resuspend removed: the kernel IPCC patch fixes the wake,
  #  so those workarounds are redundant — see the NOTE above.)
  install -Dm755 "${srcdir}/sdam-debug-pre" \
    "${pkgdir}/usr/lib/pocknix/sleep.d/pre/003-sdam-debug"
  install -Dm755 "${srcdir}/sdam-debug-post" \
    "${pkgdir}/usr/lib/pocknix/sleep.d/post/003-sdam-debug"

  # Pin deep-only suspend (drop systemd's mem->standby->freeze fall-through; s2idle
  # can wedge on SM8550). systemd reads sleep.conf drop-ins from this vendor dir.
  install -Dm644 "${srcdir}/10-pocknix-deeponly.conf" \
    "${pkgdir}/usr/lib/systemd/sleep.conf.d/10-pocknix-deeponly.conf"
  # Power button: wake-and-stay (HandlePowerKey=ignore) instead of systemd's default
  # poweroff (which made a wake-press shut the device down). Sleep via the Steam menu.
  install -Dm644 "${srcdir}/20-pocknix-powerkey.conf" \
    "${pkgdir}/usr/lib/systemd/logind.conf.d/20-pocknix-powerkey.conf"
  # cpuidle quirk: disable cpu0 idle state1 (GMU issues) — ROCKNIX SM8550 096-cpuidle,
  # re-asserted every boot via systemd-tmpfiles.
  install -Dm644 "${srcdir}/30-pocknix-cpuidle.conf" \
    "${pkgdir}/usr/lib/tmpfiles.d/30-pocknix-cpuidle.conf"

  # InputPlumber composite-device config + capability_map for the RP6 RSInput gamepad
  # (the map fixes the driver's X/Y swap + d-pad; device config targets the Steam Deck pad).
  install -Dm644 "${srcdir}/01-rsinput-rp6.yaml" \
    "${pkgdir}/usr/share/inputplumber/devices/01-rsinput-rp6.yaml"
  install -Dm644 "${srcdir}/rp6-gamepad.yaml" \
    "${pkgdir}/usr/share/inputplumber/capability_maps/rp6-gamepad.yaml"

  # udev rule: let the 'video' group (non-root session user) write panel brightness
  # so Steam's brightness slider works as the deck user.
  install -Dm644 "${srcdir}/90-pocknix-backlight.rules" \
    "${pkgdir}/usr/lib/udev/rules.d/90-pocknix-backlight.rules"
  # Controller uaccess for the non-root deck session (ALARM has no game-devices-udev). Critical for
  # the InputPlumber 'deck' target (Valve 28de) hidraw that Steam Input reads.
  install -Dm644 "${srcdir}/60-pocknix-controllers.rules" \
    "${pkgdir}/usr/lib/udev/rules.d/60-pocknix-controllers.rules"

  # ALSA UCM for the RP6 sound card (reports as "AYN-Odin2"). The codec include
  # sequences (/lib, /codecs/wcd938x, /codecs/qcom-lpass) come from base alsa-ucm-conf.
  local ucm="${pkgdir}/usr/share/alsa/ucm2"
  install -Dm644 "${srcdir}/AYN-Odin2.conf" "${ucm}/AYN/Odin2/AYN-Odin2.conf"
  install -Dm644 "${srcdir}/HiFi.conf"      "${ucm}/AYN/Odin2/HiFi.conf"
  # card-match file (matched by card longname under the sm8550 driver dir)
  install -d "${ucm}/conf.d/sm8550"
  ln -sf "../../AYN/Odin2/AYN-Odin2.conf" "${ucm}/conf.d/sm8550/AYN-Odin2.conf"
}
