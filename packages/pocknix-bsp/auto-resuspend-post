#!/bin/sh
# Auto-resuspend on a spurious wake.
#
# Layer 3 (see docs/sm8550-suspend-wake-report.md): the residual deep-sleep wake is the ADSP
# charger firmware's pmic_glink doorbell on the IRQF_NO_SUSPEND IPCC line — it can't be masked,
# so instead we just go back to sleep when the wake wasn't the user. A USER wake is the power
# button, which increments the pwrkey IRQ; a spurious ADSP wake does not. So: if pwrkey did NOT
# change across this sleep, re-suspend; otherwise leave the device awake.
#
# Safety:
#  - Fails OPEN: any missing/NONE/empty reading -> do nothing (never trap the user in a loop).
#  - Escape hatch: `touch /run/pocknix-no-resuspend` disables it until next boot.
[ -e /run/pocknix-no-resuspend ] && exit 0

before=$(cat /run/pocknix-pwrkey.count 2>/dev/null)
now=$(awk '/pwrkey/{f=1; for(i=2;i<=NF;i++) if($i ~ /^[0-9]+$/) s+=$i} END{print (f ? s : "NONE")}' \
        /proc/interrupts)

# fail open on any ambiguous reading (empty before/now, or no pwrkey line found)
case "${before}:${now}" in
  *NONE*|:*|*:) exit 0 ;;
esac

if [ "${now}" = "${before}" ]; then
  echo "pocknix: spurious wake (power key did not fire) -> re-suspending in 3s" > /dev/kmsg
  # Schedule a detached re-suspend so systemd-sleep finishes the current resume first.
  systemd-run --on-active=3s --timer-property=AccuracySec=1s \
    systemctl suspend >/dev/null 2>&1 || true
fi
exit 0
