# pocknix-steam — native ARM64 Steam (Big Picture under gamescope) for the Retroid Pocket 6.
# Ships the native-ARM client installer (ported from ROCKNIX "Install Steam.sh") + the gamescope
# launcher. The stock x86 steam-launcher .deb is NOT used (it pulls x86 binaries). Native ARM
# Steam is experimental (Valve publicbeta linuxarm64).
pkgname=pocknix-steam
pkgver=0.1.0
pkgrel=1
pkgdesc="Native ARM64 Steam Big Picture (gamescope) for the RP6 — installer + launcher"
arch=('any')
url="https://github.com/shuuri-labs/pocknix-os"
license=('GPL2')
# gamescope = our ROCKNIX-patched compositor; wget/unzip/curl/tar fetch+unpack the client.
# seatd (gamescope seat) + pipewire (audio) come from the base image.
# gtk2 (built by us; EOL in Arch) + gdk-pixbuf2 = libs steamui.so dlopens. Two deps the native
# arm64 client needs that nothing else pulls in on a from-scratch ALARM base (Fedora/armada get
# them transitively) — found via ldd ... | grep 'not found':
#   openal   -> libopenal.so.1, a DT_NEEDED of vgui2_s.so; missing => "Could not load module
#               'bin/vgui2_s.dll'" (the .so opens but dlopen fails on the unresolved dep).
#   libcups  -> libcups.so.2, a DT_NEEDED of steamwebhelper + libcef.so (CEF always links cups
#               for print support); missing => steamwebhelper (the Big-Picture CEF UI) crash-loops.
# lsof: not a lib but a runtime tool — Steam shells out to `lsof` to find the port steamwebhelper
#   listens on for its CEF websocket (steamui<->web UI IPC); missing => "Failed to connect to
#   websocket" and gamepadui never connects.
# noto-fonts(+cjk/emoji): the gamepadui renders UI text via system fonts (fontconfig). Without CJK
#   coverage the language selector shows tofu for Chinese/Japanese/Korean (Latin works regardless).
# networkmanager: Steam's gamepadui manages Wi-Fi exclusively via the NetworkManager D-Bus API
#   (like SteamOS; ROCKNIX's steam pkg depends on it too). Without an NM backend the setup wizard
#   shows "no connections found" even when online. NB: NM must actually run + manage wlan0 (via the
#   iwd backend) — see build-sd-image.sh network plumbing, not just this dep.
# xorg-server-xvfb provides the virtual X display used to bootstrap the client (no FEX). The
# rest of the native client's deps resolve from the base image / the steamrt runtime.
depends=('gamescope' 'wget' 'unzip' 'curl' 'tar' 'gtk2' 'gdk-pixbuf2' 'openal' 'libcups' 'lsof'
         'noto-fonts' 'noto-fonts-cjk' 'noto-fonts-emoji' 'networkmanager' 'pocknix-steamos-shim'
         'xorg-server-xvfb')
source=('pocknix-steam-install' 'pocknix-steam' 'registry.vdf')
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
  install -Dm755 "${srcdir}/pocknix-steam-install" "${pkgdir}/usr/bin/pocknix-steam-install"
  install -Dm755 "${srcdir}/pocknix-steam"         "${pkgdir}/usr/bin/pocknix-steam"
  # OOBE-complete registry seed (ROCKNIX resources/registry.vdf). Seeded to ~/.steam/registry.vdf
  # by the installer so the gamepadui skips the Steam Deck OOBE — whose "required update" step
  # tries to update SteamOS (which we aren't) and dead-ends with "Updater apply error: 2".
  install -Dm644 "${srcdir}/registry.vdf"          "${pkgdir}/usr/share/pocknix-steam/registry.vdf"
}
