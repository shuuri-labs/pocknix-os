#!/bin/bash
# pocknix-steam — launch the native ARM64 Steam client in Big Picture under gamescope on the RP6.
# Client setup modeled on armada's launch-steam (native, NON-FEX): cd into steamrtarm64,
# steamrtarm64 first on LD_LIBRARY_PATH. Panel geometry fixed for the RP6.
#
# Performance overlay: gamescope --mangoapp spawns the `mangoapp` process (from the mangohud dep)
# that Steam's built-in 'Performance' overlay drives. IMPORTANT: it only renders once you enable
# Steam Settings > In Game > Performance > "Show performance metrics in this game" — the overlay
# being blank in earlier testing was that toggle being OFF, NOT a mangoapp/gamescope coupling
# problem. So this is just `--mangoapp` + the mangohud dep; no MANGOHUD_CONFIGFILE plumbing needed.
# GPU stats are limited on Adreno/msm but FPS/CPU/frametime render. See progress.md.
set -e

export HOME="${HOME:-/root}"
STEAM="${HOME}/.local/share/Steam"
CLIENT_DIR="${STEAM}/steamrtarm64"
CLIENT="${CLIENT_DIR}/steam"

# armada's LD_LIBRARY_PATH: the client's own dir FIRST (bundled libvpx.so.6 etc.), then the
# aarch64 shim dir (libibus shim). steamrtarm64/steam re-execs into its runtime from here.
LDLP="${CLIENT_DIR}:${STEAM}/lib/aarch64-linux-gnu"

# install the native client + runtime on first run
if [ ! -x "${CLIENT}" ]; then
  /usr/bin/pocknix-steam-install
fi

# CRITICAL: Steam resolves its legacy module paths (bin/vgui2_s.dll …) RELATIVE TO getcwd.
# armada cd's into steamrtarm64 before launch; cd'ing to $HOME makes 'bin/vgui2_s' unresolvable
# -> "Could not load module 'bin/vgui2_s.dll'". gamescope passes CWD to the client.
cd "${CLIENT_DIR}" 2>/dev/null || { echo "missing ${CLIENT_DIR}" >&2; exit 1; }

# Decky/CEF debugger marker armada touches (harmless if unused).
touch "${STEAM}/.cef-enable-remote-debugging" 2>/dev/null || true

# RP6 panel: native 1080x1920@120 portrait, mounted rotation=270 -> landscape 1920x1080,
# rotated in-shader (--use-rotation-shader, --force-orientation left). See gamescope-rp6-gpu.
W=1920; H=1080; REFRESH=120; ORIENT=left

# Steam client flags = armada's gamescope-session CLIENTCMD exactly
# (`-gamepadui -steamos3 -steampal -steamdeck -noverifyfiles`). `-e` = gamescope --steam.
exec env -u WAYLAND_DISPLAY \
  GAMESCOPE_FAKE_OUTPUT_MM=508x286 \
  LD_LIBRARY_PATH="${LDLP}" \
  gamescope -W "${W}" -H "${H}" -r "${REFRESH}" --xwayland-count 2 --mangoapp --backend drm \
    --force-orientation "${ORIENT}" --use-rotation-shader -e -- \
    "${CLIENT}" -gamepadui -steamos3 -steampal -steamdeck -noverifyfiles
