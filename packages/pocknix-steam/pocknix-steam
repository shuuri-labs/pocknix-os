#!/bin/bash
# pocknix-steam — launch the native ARM64 Steam client in Big Picture under gamescope on the RP6.
# Modeled on armada's system_files/usr/libexec/armada/launch-steam (native, NON-FEX): cd into
# steamrtarm64, steamrtarm64 first on LD_LIBRARY_PATH, exec the native client. Panel geometry is
# fixed for the RP6 (we have no sway to probe) and we wrap the client in gamescope ourselves.
set -e

export HOME="${HOME:-/root}"
STEAM="${HOME}/.local/share/Steam"
CLIENT_DIR="${STEAM}/steamrtarm64"
CLIENT="${CLIENT_DIR}/steam"

# armada's LD_LIBRARY_PATH: the client's own dir FIRST (bundled libvpx.so.6 etc.), then the
# aarch64 shim dir (libibus shim). steamrtarm64/steam re-execs into its runtime from here.
LDLP="${CLIENT_DIR}:${STEAM}/lib/aarch64-linux-gnu"

# install the native client + runtime on first run
if [ ! -x "${CLIENT}" ]; then
  /usr/bin/pocknix-steam-install
fi

# CRITICAL: Steam resolves its legacy module paths (bin/vgui2_s.dll …) RELATIVE TO getcwd.
# armada cd's into steamrtarm64 before exec; cd'ing to $HOME (as we did) makes 'bin/vgui2_s'
# unresolvable -> "Could not load module 'bin/vgui2_s.dll'". gamescope passes CWD to the client.
cd "${CLIENT_DIR}" 2>/dev/null || { echo "missing ${CLIENT_DIR}" >&2; exit 1; }

# Decky/CEF debugger marker armada touches (harmless if unused).
touch "${STEAM}/.cef-enable-remote-debugging" 2>/dev/null || true

# Steam's built-in performance overlay = gamescope's --mangoapp spawning the `mangoapp` process,
# whose display level Steam controls by writing to MANGOHUD_CONFIGFILE. Both gamescope/mangoapp AND
# steam must inherit this env var, else Steam logs "Failed to determine mangoapp config path" and
# the overlay never draws even though mangoapp is running. Seed it "no_display" so nothing shows
# until Steam sets a level. (This is exactly what ChimeraOS gamescope-session-plus does; ROCKNIX
# only passes --mangoapp and relies on a default $HOME path.)
export MANGOHUD_CONFIGFILE="$(mktemp "${XDG_RUNTIME_DIR:-/tmp}/mangohud.XXXXXX")"
echo "no_display" > "${MANGOHUD_CONFIGFILE}"

# RP6 panel: native 1080x1920@120 portrait, mounted rotation=270 -> landscape 1920x1080,
# rotated in-shader (--use-rotation-shader, --force-orientation left). See gamescope-rp6-gpu.
W=1920; H=1080; REFRESH=120; ORIENT=left

# Steam client flags: match armada's gamescope-session steam CLIENTCMD EXACTLY
# (`-gamepadui -steamos3 -steampal -steamdeck -noverifyfiles`). We previously inherited ROCKNIX's
# extra skip-flags (-nobootstrapupdate -skipinitialbootstrap -norepairfiles -noshaders) — but
# -skipinitialbootstrap suppresses the step that extracts/places bin/vgui2_s from the .zip.vz
# payload, so the gamepadui launch fataled with "Could not load module 'bin/vgui2_s.dll'".
exec env -u WAYLAND_DISPLAY \
  GAMESCOPE_FAKE_OUTPUT_MM=508x286 \
  MANGOHUD_CONFIGFILE="${MANGOHUD_CONFIGFILE}" \
  LD_LIBRARY_PATH="${LDLP}" \
  gamescope -W "${W}" -H "${H}" -r "${REFRESH}" --xwayland-count 2 --mangoapp --backend drm \
    --force-orientation "${ORIENT}" --use-rotation-shader -e -- \
    "${CLIENT}" -gamepadui -steamos3 -steampal -steamdeck -noverifyfiles
