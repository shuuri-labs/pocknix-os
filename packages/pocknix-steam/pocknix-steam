#!/bin/bash
# pocknix-steam — launch the native ARM64 Steam client in Big Picture under gamescope on the RP6.
# Client setup modeled on armada's launch-steam (native, NON-FEX): cd into steamrtarm64,
# steamrtarm64 first on LD_LIBRARY_PATH. Panel geometry fixed for the RP6.
#
# Performance overlay: gamescope --mangoapp spawns the `mangoapp` process (from the mangohud dep)
# that Steam's built-in 'Performance' overlay drives. IMPORTANT: it only renders once you enable
# Steam Settings > In Game > Performance > "Show performance metrics in this game" — the overlay
# being blank in earlier testing was that toggle being OFF, NOT a mangoapp/gamescope coupling
# problem. So this is just `--mangoapp` + the mangohud dep; no MANGOHUD_CONFIGFILE plumbing needed.
# GPU load/clock/temp + power draw now render too (mangohud carries the ROCKNIX/armada Adreno+
# Qualcomm reader patches — vanilla mangohud has no msm/freedreno reader). See progress.md.
set -e

export HOME="${HOME:-/root}"
STEAM="${HOME}/.local/share/Steam"
CLIENT_DIR="${STEAM}/steamrtarm64"
CLIENT="${CLIENT_DIR}/steam"

# armada's LD_LIBRARY_PATH: the client's own dir FIRST (bundled libvpx.so.6 etc.), then the
# aarch64 shim dir (libibus shim). steamrtarm64/steam re-execs into its runtime from here.
LDLP="${CLIENT_DIR}:${STEAM}/lib/aarch64-linux-gnu"

# First run: lay down the native client + runtime. Prefer the BUILD-TIME bake (offline) — a seed
# tarball of a fully-bootstrapped, HOME-agnostic Steam tree shipped in the image — so first boot
# needs no network. Fall back to the network installer only if no seed is present.
SEED=/usr/share/pocknix-steam/steam-seed.tar.zst
if [ ! -x "${CLIENT}" ]; then
  if [ -f "${SEED}" ]; then
    echo "[pocknix-steam] seeding the baked Steam client (offline, $(du -h "${SEED}" 2>/dev/null | cut -f1) — can take a FEW MINUTES on a slow SD, faster on internal)..."
    mkdir -p "${HOME}"
    # --checkpoint prints progress every N records so a slow SD extract isn't a silent "hang".
    if tar -C "${HOME}" --checkpoint=2000 --checkpoint-action=echo='[pocknix-steam]   extracting… (%u records)' -xf "${SEED}"; then
      echo "[pocknix-steam] seed extracted."
    else
      echo "[pocknix-steam] seed extract failed; falling back to download" >&2; /usr/bin/pocknix-steam-install
    fi
  else
    /usr/bin/pocknix-steam-install
  fi
fi

# CRITICAL: Steam resolves its legacy module paths (bin/vgui2_s.dll …) RELATIVE TO getcwd.
# armada cd's into steamrtarm64 before launch; cd'ing to $HOME makes 'bin/vgui2_s' unresolvable
# -> "Could not load module 'bin/vgui2_s.dll'". gamescope passes CWD to the client.
cd "${CLIENT_DIR}" 2>/dev/null || { echo "missing ${CLIENT_DIR}" >&2; exit 1; }

# Decky/CEF debugger marker armada touches (harmless if unused).
touch "${STEAM}/.cef-enable-remote-debugging" 2>/dev/null || true

# Pin the client beta channel EVERY launch. The native ARM64 Big-Picture client only works on
# steamdeck_publicbeta; if anything flips package/beta to steamdeck_stable (e.g. a desktop-mode
# `steam` launch, or a server-side channel change), Steam sees "installed version 0" for the new
# channel and dead-ends forever on "Installing update" with steamwebhelper crash-looping -> the
# session hangs. Re-asserting it here makes the session self-heal on the next launch.
mkdir -p "${STEAM}/package"
echo steamdeck_publicbeta > "${STEAM}/package/beta"

# --- FEX/Proton prep for x86 game content (mirrors ROCKNIX steam_arm64_binfmt_and_proton_prep) ---
# Re-applied EVERY launch because Steam restores Valve's files on a Proton update and binfmt resets on
# boot. Needs root for the binfmt write (the boot-to-Steam session runs as root). See the 2026-06-22
# milestone in progress.md for the why.
PROTON_DIR="${STEAM}/steamapps/common/Proton 11.0 (ARM64)"
if [ -d "${PROTON_DIR}" ]; then
  # 1) Replace Valve's toolmanifest with our require_tool_appid-free one so Proton runs DIRECTLY
  #    (Valve's runs it inside the SteamLinuxRuntime_4-arm64 container, which Steam can't set up here).
  install -Dm644 /usr/share/pocknix-steam/proton-toolmanifest.vdf "${PROTON_DIR}/toolmanifest.vdf" 2>/dev/null || true
  # 2) Register the (gated) library ARM Proton as a selectable compat tool: symlink the dist in +
  #    drop our compatibilitytool.vdf (install_path ".").
  TOOLDIR="${STEAM}/compatibilitytools.d/proton-11-arm64"
  mkdir -p "${TOOLDIR}"
  ln -sfn "${PROTON_DIR}"/* "${TOOLDIR}/" 2>/dev/null || true
  install -Dm644 /usr/share/pocknix-steam/proton-compatibilitytool.vdf "${TOOLDIR}/compatibilitytool.vdf" 2>/dev/null || true
fi
# 3) (binfmt) The FEX x86 binfmt handlers are disabled at BOOT by pocknix-fex-binfmt-off.service —
#    done there, as root, because the non-root 'deck' session can't write /proc/sys/fs/binfmt_misc.
#    Leaving binfmt on breaks Steam's Proton compat-tool setup (x86 game content goes Wine->FEX
#    directly, not via Linux binfmt). See overlay/etc/systemd/system/pocknix-fex-binfmt-off.service.

# Self-heal a session SWITCH: steamos-session-select SIGTERMs gamescope to go to Plasma, but the
# Steam client re-parents and keeps running (with its single-instance lock). On the way back the new
# steam logs "Steam is already running, exiting", gamescope's primary child dies instantly, and the
# supervisor hot-loops (black flashes). Clear any leftover Steam before launching so this instance
# owns the session. Only ever runs at game-session START, when no legit Steam should be alive.
uid="$(id -u)"
if pgrep -u "${uid}" -x steam >/dev/null 2>&1 || pgrep -u "${uid}" -f steamwebhelper >/dev/null 2>&1; then
  echo "[pocknix-steam] clearing a stale Steam from a previous session..."
  env LD_LIBRARY_PATH="${LDLP}" "${CLIENT}" -shutdown >/dev/null 2>&1 || true
  for _ in $(seq 1 8); do pgrep -u "${uid}" -x steam >/dev/null 2>&1 || break; sleep 1; done
  pkill -u "${uid}" -KILL -x steam        2>/dev/null || true
  pkill -u "${uid}" -KILL -f steamwebhelper 2>/dev/null || true
fi

# RP6 panel: the DRM connector exposes 1080x1920@120 (preferred) AND 1080x1920@60 — both PHYSICAL
# (portrait) modes; the panel is mounted rotation=270. We MIRROR ROCKNIX exactly: pass gamescope the
# panel's PHYSICAL mode dims (-W 1080 -H 1920, == swaymsg current_mode on ROCKNIX) and let
# --force-orientation left + --use-rotation-shader rotate content to landscape for apps.
#
# WHY physical dims: gamescope matches modes by the -W/-H it's given, and the panel's DRM modes are
# 1080x1920 (@120 and @60). Passing landscape 1920x1080 (no such mode) made gamescope back-map; the
# physical 1080x1920 matches the real modes (so -r 60 below picks 1080x1920@60).
#
# REFRESH: ROCKNIX does NOT leave refresh to gamescope — it reads a SYSTEM setting (system.display_mode)
# into sway, then passes `gamescope -r <hz>` at launch (start_steam.sh: REFRESH_HZ from swaymsg
# current_mode). We have no sway, so we drive -r from POCKNIX_REFRESH (default 120; set 60 for a 60 Hz
# session). The panel exposes 1080x1920@60, so gamescope selects it at launch. NB Steam's in-game
# refresh slider does NOT reach gamescope here (its mode-switch request prints nothing in the gamescope
# log) — ROCKNIX gets 60 Hz the same launch-time way, not via the in-game slider. See gamescope-refresh-edid.
W=1080; H=1920; ORIENT=left
REFRESH="${POCKNIX_REFRESH:-120}"
# Pin the whole game tree (gamescope + steam + game + FEX) to the SM8550's big cores, mirroring
# ROCKNIX's EMUPERF=FAST_CORES. 0-2 = A510 littles, 3-7 = A710/A715 mids + X3 prime. On-device A/B
# CONFIRMED this helps: widening to 0-7 DROPS in-game FPS (the scheduler strands hot threads on the
# slow littles). gamescope's children inherit its affinity, so one taskset covers the whole tree.
FAST_CORES=3-7
# ROCKNIX: GAMESCOPE_MODE_SAVE_FILE=/storage/.config/gamescope/modes.cfg (persists/loads the DRM
# mode; required for mode-switching) + touch it so it exists before gamescope starts. deck equivalent:
GS_MODE_FILE="${HOME}/.config/gamescope/modes.cfg"
mkdir -p "$(dirname "${GS_MODE_FILE}")" 2>/dev/null || true
touch "${GS_MODE_FILE}" 2>/dev/null || true
# ROCKNIX clears any forced mesa driver right before launch so Turnip auto-selects.
unset MESA_LOADER_DRIVER_OVERRIDE

# Steam client flags = armada's gamescope-session CLIENTCMD exactly
# (`-gamepadui -steamos3 -steampal -steamdeck -noverifyfiles`). `-e` = gamescope --steam.
#
# LD_LIBRARY_PATH is set on the CLIENT via an INNER `env`, NOT on gamescope's environment. gamescope
# carries CAP_SYS_NICE (a file capability, for realtime scheduling — see packages/gamescope), which
# puts it in glibc secure-execution mode (AT_SECURE). In that mode glibc *removes* LD_LIBRARY_PATH
# from the environment entirely; the steam client (gamescope's child) would then inherit an env
# WITHOUT it and fail to load steamui.so's bundled libvpx.so.6 from steamrtarm64. Re-injecting it
# with `env` right before the client restores it for the (non-secure) client. gamescope itself does
# not need LD_LIBRARY_PATH (its libs are in the system paths).
# Tee gamescope's output to a log (it otherwise goes to tty1 and is lost). Write it in the deck HOME
# (deck can't write /var/log — that failed with "Permission denied" and lost the log). pocknix-diag
# picks it up. Truncated each launch. NOT exec'd so the pipe stays intact; pkill -TERM gamescope
# (session switch) still works (targets by name).
GS_LOG="${HOME}/pocknix-steam.log"
set -o pipefail
# Steam's gamepadui sizes its UI from the output's physical mm (DPI). 177x100 = armada's tested RP6
# value (~275 DPI, handheld-correct UI); the old 508x286 was ~96 DPI -> a desktop monitor -> tiny UI.
env -u WAYLAND_DISPLAY \
  GAMESCOPE_FAKE_OUTPUT_MM=177x100 \
  GAMESCOPE_MODE_SAVE_FILE="${GS_MODE_FILE}" \
  taskset -c "${FAST_CORES}" \
  gamescope -W "${W}" -H "${H}" -r "${REFRESH}" --xwayland-count 2 --mangoapp --backend drm \
    --force-orientation "${ORIENT}" --use-rotation-shader -e -- \
    env LD_LIBRARY_PATH="${LDLP}" "${CLIENT}" -gamepadui -steamos3 -steampal -steamdeck -noverifyfiles \
  2>&1 | tee "${GS_LOG}"
