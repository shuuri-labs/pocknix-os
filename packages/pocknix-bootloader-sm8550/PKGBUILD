# pocknix-bootloader-sm8550 — the ROCKNIX ABL install kit for SM8550 boards.
#
# SM8550 boot contract (qcom-abl): XBL -> ABL -> /KERNEL (Android boot image)
# off the FAT labeled ROCKNIX. The FACTORY ABL only boots Android — the ROCKNIX
# ABL must be flashed to the internal abl_a/abl_b partitions ONCE before any SD
# can boot. This package ships ROCKNIX's own install kit (the rocknix_abl/
# folder their release images carry): the signed ABL elf plus the Android-side
# backup/flash/restore scripts, so a stock-Android device can be provisioned
# straight from a pocknix SD with no ROCKNIX install first. build-sd-image.sh
# copies the folder to the SD boot FAT root — the exact layout and flow ROCKNIX
# documents (see the kit's README). (Contrast sm8250, arm-efi, where the
# factory ABL chainloads UEFI GRUB and no ABL flash is needed.)
#
# Contents and provenance:
#   abl_signed-SM8550.elf   OFFICIAL ROCKNIX RELEASE ARTIFACT, fetched from
#                           github.com/ROCKNIX/abl by pinned tag + sha512 and
#                           re-verified against the release's own .sha256
#                           sidecar in prepare(). One elf covers the whole
#                           SM8550 family (RP6 + Odin 2 family) — ROCKNIX keys
#                           it by SoC, not board. See README.provenance.
#   README, flash_abl.sh(.template), backup_abl.sh, restore_backup_abl.sh
#                           vendored VERBATIM from the ROCKNIX distribution
#                           repo (packages/tools/rocknix-abl/sources); the
#                           %DEVICE% substitution in flash_abl.sh mirrors
#                           their package.mk exactly.
#
# Nothing here flashes anything at build or install time — the kit is inert
# files the user runs by hand from rooted stock Android (per the kit README).
# pocknix deliberately ships NO auto-flash hook (ROCKNIX's updateabl rewrites
# internal abl_a/abl_b on every OS update; we don't).
#
# Version bump: set _ablver to the new release tag (watch ROCKNIX's pin in
# their packages/tools/rocknix-abl/package.mk during `make sync` review — the
# ABL and the boot contract above must stay matched), reset pkgrel=1, refresh
# the tarball sha512.
pkgname=pocknix-bootloader-sm8550
_ablver=1.1.5
pkgver=${_ablver}
pkgrel=1
pkgdesc="SM8550 qcom-abl boot payload: ROCKNIX ABL install kit (rocknix_abl)"
arch=('aarch64')
url="https://github.com/shuuri-labs/pocknix-os"
license=('BSD-3-Clause')   # Qualcomm ABL (edk2 LinuxLoader); kit scripts GPL-2.0
source=("https://github.com/ROCKNIX/abl/releases/download/v${_ablver}/rocknix-abl-v${_ablver}.tar.gz"
        'README'
        'flash_abl.sh.template'
        'backup_abl.sh'
        'restore_backup_abl.sh')
sha512sums=('dffcefb9975880f1e54da3538bac0598b67761af662a4e7365e36c81ba109797ff44a5d23deea0a4999deae185f5bc24609e4c6037d68fc916ffeaaa6492234e'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

prepare() {
  # The release ships a .sha256 sidecar per elf — verify the one we ship.
  ( cd "rocknix-abl-v${_ablver}" && sha256sum -c "abl_signed-SM8550.elf.sha256" )
  # ROCKNIX package.mk substitution: the flash script names the SoC's elf.
  sed 's/%DEVICE%/SM8550/g' flash_abl.sh.template > flash_abl.sh
}

package() {
  local kit="${pkgdir}/usr/share/pocknix/bootloader/rocknix_abl"

  install -Dm644 "rocknix-abl-v${_ablver}/abl_signed-SM8550.elf" "${kit}/abl_signed-SM8550.elf"
  install -Dm644 README                 "${kit}/README"
  install -Dm755 flash_abl.sh           "${kit}/flash_abl.sh"
  install -Dm755 backup_abl.sh          "${kit}/backup_abl.sh"
  install -Dm755 restore_backup_abl.sh  "${kit}/restore_backup_abl.sh"
}
