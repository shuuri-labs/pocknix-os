#!/bin/bash
# pocknix-roms-init — first-login setup for the emulation layer, run as the 'deck' user by
# pocknix-roms-init.service (a --user oneshot). Two jobs, both idempotent:
#
#   1. Create the ROM drop tree ~/ROMs/<system> + ~/ROMs/bios, and drop ROMS-README.txt so the
#      user knows exactly where to copy ROMs / BIOS / Switch keys. This is the whole "drop your
#      files in a folder and they're picked up" promise — ES-DE scans ~/ROMs by default.
#
#   2. Seed the ES-DE + RetroArch configs into $HOME IF THE USER HAS NONE (never clobber user
#      edits). A pacman package cannot write /home/deck at install time, so the staged copies live
#      in /usr/share/pocknix-emulation and land here on first login instead (robust-location
#      pattern — see the fixes-go-in-robust-locations rationale in the repo).
#
# Safe to run repeatedly; re-runs only create what's missing. Guarded so it never fails the login.
set -u

SHARE=/usr/share/pocknix-emulation
ROMS="${HOME}/ROMs"

# ES-DE default folder names. Curated to the pocknix console list (RetroArch-core systems + the
# standalone heavy hitters: gc/wii/wiiu, ps2, ps3, psvita, switch, xbox, n3ds). Creating the dir
# just gives the user a labelled place to drop ROMs; ES-DE still only SHOWS systems once populated.
SYSTEMS=(
  nes snes n64 gb gbc gba nds n3ds
  genesis megadrive mastersystem gamegear segacd saturn dreamcast
  tg16 pcengine neogeo arcade mame
  atari2600 atari7800 atarilynx atarijaguar wonderswan
  psx ps2 ps3 psp psvita
  gc wii wiiu switch xbox
)

mkdir -p "${ROMS}/bios"
for s in "${SYSTEMS[@]}"; do mkdir -p "${ROMS}/${s}"; done

# Drop the guidance file at the root of the tree (refresh it each run so doc updates propagate).
if [ -f "${SHARE}/ROMS-README.txt" ]; then
  cp -f "${SHARE}/ROMS-README.txt" "${ROMS}/README.txt" 2>/dev/null || true
fi

# --- seed ES-DE custom find-rules (only if the user has none) ---
# ES-DE reads custom emulator lookup rules from ~/ES-DE/custom_systems/es_find_rules.xml. Ours
# points ES-DE at the pocknix emulator install paths (see that file).
ESDE_CUSTOM="${HOME}/ES-DE/custom_systems"
if [ -f "${SHARE}/es_find_rules.xml" ] && [ ! -f "${ESDE_CUSTOM}/es_find_rules.xml" ]; then
  mkdir -p "${ESDE_CUSTOM}"
  cp "${SHARE}/es_find_rules.xml" "${ESDE_CUSTOM}/es_find_rules.xml" 2>/dev/null || true
fi

# (Steam ROM Manager is RETIRED from the sync flow — its Electron CLI deadlocked on every display
# backend on-device 2026-07-05. ES-DE + favorites reach Steam via pocknix-steam-sync's direct
# shortcuts.vdf write, run by pocknix-steam at session start. The steam-rom-manager PKGBUILD
# remains in-tree as an optional desktop tool; nothing here seeds or reads its config anymore.)

# --- seed RetroArch joypad autoconfig profiles (only what's missing) ---
# From retroarch-autoconfig-pocknix (/usr/share/libretro/autoconfig). Copied (not symlinked) into
# RetroArch's default, WRITABLE autoconfig dir so user-saved custom profiles coexist. Without
# these, RetroArch sees Steam Input's virtual X360 pad but has no bindings: controls fully dead
# (bitten on-device 2026-07-06). -n = never clobber a user-customized profile.
RA_AUTOCFG_SRC=/usr/share/libretro/autoconfig/udev
RA_AUTOCFG_DST="${HOME}/.config/retroarch/autoconfig/udev"
if [ -d "${RA_AUTOCFG_SRC}" ]; then
  mkdir -p "${RA_AUTOCFG_DST}"
  cp -n "${RA_AUTOCFG_SRC}/"*.cfg "${RA_AUTOCFG_DST}/" 2>/dev/null || true
fi

# --- link the vendored slang shader set into RetroArch's shader dir ---
# From retroarch-shaders-pocknix. Symlink (not copy — 79 MB): the shader dir itself stays the
# writable user default so preset saving keeps working; presets reference shaders relative to the
# shader dir and resolve through the link. Skipped if the user already has a real shaders_slang
# (e.g. downloaded via Online Updater before this package existed).
RA_SHADERS_SRC=/usr/share/libretro/shaders/shaders_slang
RA_SHADERS_DST="${HOME}/.config/retroarch/shaders/shaders_slang"
if [ -d "${RA_SHADERS_SRC}" ] && [ ! -e "${RA_SHADERS_DST}" ]; then
  mkdir -p "${HOME}/.config/retroarch/shaders"
  ln -s "${RA_SHADERS_SRC}" "${RA_SHADERS_DST}" 2>/dev/null || true
fi

# --- seed per-system RetroArch tuning (content-dir overrides + shader presets) ---
# From /usr/share/pocknix-emulation/retroarch-config (e.g. mGBA/gba.cfg = integer scaling,
# mGBA/gba.slangp = lcd3x). cp -Rn: a user's own saved overrides/presets are never clobbered.
RA_CONF_SRC=/usr/share/pocknix-emulation/retroarch-config
RA_CONF_DST="${HOME}/.config/retroarch/config"
if [ -d "${RA_CONF_SRC}" ]; then
  mkdir -p "${RA_CONF_DST}"
  cp -Rn "${RA_CONF_SRC}/." "${RA_CONF_DST}/" 2>/dev/null || true
fi

# --- seed RetroArch defaults (only if the user has no retroarch.cfg) ---
# system_directory -> ~/ROMs/bios etc. RetroArch expands any missing keys itself on first run, so a
# minimal seed is fine; if the user already has a config we leave it entirely alone.
RA_CFG="${HOME}/.config/retroarch/retroarch.cfg"
if [ -f "${SHARE}/retroarch.cfg" ] && [ ! -f "${RA_CFG}" ]; then
  mkdir -p "${HOME}/.config/retroarch"
  cp "${SHARE}/retroarch.cfg" "${RA_CFG}" 2>/dev/null || true
fi

exit 0
