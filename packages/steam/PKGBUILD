# steam — Valve's Steam launcher/bootstrap (same approach as ROCKNIX). This package only
# ships the arch-agnostic launcher scripts from the official steam-launcher .deb; the actual
# client (the native ARM64 runtime, "steamrtarm64") is downloaded at first run by the
# bootstrapper. The root-user guard is stripped so it can run on this single-user appliance.
#
# NOTE: native ARM64 Steam is experimental. First launch must bootstrap the client:
#   steam -steamdeck -exitsteam      (downloads steamrtarm64 into ~/.local/share/Steam)
# then the session launches ~/.local/share/Steam/steamrtarm64/steam under gamescope.
pkgname=steam
pkgver=1.0.0.85
pkgrel=1
pkgdesc="Steam launcher/bootstrap (native ARM64 client fetched at first run)"
arch=('aarch64')
url="https://steampowered.com"
license=('custom')
# Host libs the client/bootstrap leans on; the steamrt runtime self-provides most. Expand
# as on-device testing reveals missing .so deps.
depends=('gamescope' 'nss' 'gcc-libs' 'zenity' 'curl' 'tar')
options=('!strip')
source=("steam-launcher_${pkgver}_amd64.deb::https://repo.steampowered.com/steam/archive/stable/steam-launcher_${pkgver}_amd64.deb")
sha256sums=('SKIP')

package() {
  cd "${srcdir}"
  mkdir -p deb && ( cd deb && ar x "${srcdir}/steam-launcher_${pkgver}_amd64.deb" )
  mkdir -p root
  # data archive may be .xz or .zst depending on the .deb
  tar -C root -xf deb/data.tar.* 2>/dev/null || bsdtar -C root -xf deb/data.tar.*

  # strip the "don't run as root" guard (single-user appliance runs the session as root)
  sed -i '/[Dd]on.t allow running as root/,/^fi$/d' root/usr/lib/steam/bin_steam.sh 2>/dev/null || true

  cp -a root/usr/bin "${pkgdir}/usr/bin"
  cp -a root/usr/lib "${pkgdir}/usr/lib"
  [ -d root/usr/share ] && cp -a root/usr/share "${pkgdir}/usr/share" || true
  # license
  install -d "${pkgdir}/usr/share/licenses/${pkgname}"
  [ -f root/usr/share/doc/steam/copyright ] && \
    cp root/usr/share/doc/steam/copyright "${pkgdir}/usr/share/licenses/${pkgname}/" || true
}
