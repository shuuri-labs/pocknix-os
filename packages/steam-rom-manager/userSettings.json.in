{
  "environmentVariables": {
    "steamDirectory": "__HOME__/.local/share/Steam",
    "romsDirectory": "__HOME__/ROMs"
  },
  "offlineMode": false,
  "previewSettings": {
    "retrieveCurrentSteamImages": true,
    "disableCategories": false,
    "deleteDisabledShortcuts": false,
    "imageZoomPercentage": 40,
    "preload": false,
    "hideUserAccount": false
  },
  "autoUpdate": false
}
