#!/bin/bash
# pocknix-decky-sync — seed Decky Loader + OS-shipped plugins into deck's homebrew dir.
# Ported from armada's armada-decky-sync (user/path swap, no SELinux chcon).
#
# Decky owns its own self-updates INSIDE ~/homebrew; the image copies under /usr/share only
# SEED first installs and replace the loader when the OS bundles a NEWER version than what's
# on disk (version-compared, so a user's self-updated loader is never downgraded).
# OS-shipped plugins (PocknixControl) are re-copied every boot — they're system UI, the image
# is their source of truth; user-installed plugins in other dirs are untouched.
set -euo pipefail

user_name=deck
homebrew="/home/${user_name}/homebrew"
loader_src=/usr/share/decky-loader/PluginLoader
loader_version_src=/usr/share/decky-loader/.loader.version
src=/usr/share/decky-plugins

loader_needs_seed() {
    [[ ! -x "${homebrew}/services/PluginLoader" ]] && return 0
    [[ -f "${loader_version_src}" ]] || return 1
    [[ -f "${homebrew}/services/.loader.version" ]] || return 0

    local bundled current newest
    bundled=$(<"${loader_version_src}")
    current=$(<"${homebrew}/services/.loader.version")
    newest=$(printf '%s\n%s\n' "${current}" "${bundled}" | sort -V | tail -n1)
    [[ "${newest}" == "${bundled}" && "${bundled}" != "${current}" ]]
}

install -d -m 0755 "${homebrew}/services"
install -d -m 0755 "${homebrew}/plugins"
install -d -m 0755 "${homebrew}/settings"

# Disable any pre-existing Decky plugin_loader.service so it doesn't conflict with ours.
systemctl disable --now plugin_loader.service >/dev/null 2>&1 || true

# Decky owns self-updates; the image copy seeds installs and newer OS-bundled loaders.
if loader_needs_seed && [[ -x "${loader_src}" ]]; then
    install -Dpm 0755 "${loader_src}" "${homebrew}/services/PluginLoader"
    [[ ! -f "${loader_version_src}" ]] || install -Dpm 0644 "${loader_version_src}" "${homebrew}/services/.loader.version"
fi

if [[ ! -f "${homebrew}/settings/loader.json" ]]; then
    # Default new installs to Decky's prerelease channel for current Steam-on-ARM fixes.
    printf '{\n  "branch": 1\n}\n' >"${homebrew}/settings/loader.json"
fi

if [[ -d "$src" ]]; then
    for plugin in "$src"/*/; do
        [[ -d "$plugin" ]] || continue
        name=$(basename "$plugin")
        rm -rf "${homebrew}/plugins/${name}"
        cp -a "$plugin" "${homebrew}/plugins/${name}"
    done
fi

chown "${user_name}:${user_name}" "${homebrew}"
chown -R "${user_name}:${user_name}" "${homebrew}/services"
chown -R "${user_name}:${user_name}" "${homebrew}/plugins"
[[ ! -d "${homebrew}/settings" ]] || chown -R "${user_name}:${user_name}" "${homebrew}/settings"
