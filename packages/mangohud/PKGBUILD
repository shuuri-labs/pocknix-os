# mangohud — Vulkan/GL performance overlay + the `mangoapp` binary that gamescope --mangoapp
# spawns for Steam's built-in performance overlay. NOT in ALARM for aarch64, so we build it from
# source (same pattern as packages/gamescope). The heavy deps (imgui, implot, spdlog, vk-bootstrap,
# vkroots, vulkan-headers, vulkan-utility-libraries) are meson WRAPS — downloaded during
# `meson setup` (the build chroot has network, as gamescope's git build does). mangoapp itself
# links system glfw3 (src meson: dependency('glfw3')).
pkgname=mangohud
pkgver=0.8.4
pkgrel=1
pkgdesc="Vulkan/OpenGL FPS/frametime/CPU/GPU overlay + mangoapp for the gamescope Steam session"
arch=('aarch64')
url="https://github.com/flightlessmango/MangoHud"
license=('MIT')
depends=('gcc-libs' 'glibc' 'vulkan-icd-loader' 'libdrm' 'libcap' 'glfw' 'libglvnd' 'wayland'
         'libxkbcommon' 'libx11')
makedepends=('meson' 'ninja' 'git' 'glslang' 'vulkan-headers' 'libglvnd' 'libdrm' 'libcap'
             'glfw' 'wayland' 'wayland-protocols' 'libxkbcommon' 'libx11' 'libxrandr'
             'python-mako' 'mesa')
source=("git+https://github.com/flightlessmango/MangoHud.git#tag=v${pkgver}")
sha256sums=('SKIP')

build() {
  cd MangoHud
  # mangoapp=true builds the standalone overlay app gamescope --mangoapp launches.
  # NVIDIA backends disabled (no NVIDIA here; avoids nvml/xnvctrl deps).
  meson setup build --prefix=/usr --buildtype=plain \
    -Dmangoapp=true \
    -Dwith_nvml=disabled \
    -Dwith_xnvctrl=disabled
  meson compile -C build
}

package() {
  cd MangoHud
  meson install -C build --destdir "${pkgdir}"
}
