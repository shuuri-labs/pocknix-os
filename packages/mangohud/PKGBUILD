# mangohud — Vulkan/GL performance overlay + the `mangoapp` binary that gamescope --mangoapp
# spawns for Steam's built-in performance overlay. NOT in ALARM for aarch64, so we build it from
# source (same pattern as packages/gamescope). The heavy deps (imgui, implot, spdlog, vk-bootstrap,
# vkroots, vulkan-headers, vulkan-utility-libraries) are meson WRAPS — downloaded during
# `meson setup` (the build chroot has network, as gamescope's git build does). mangoapp itself
# links system glfw3 (src meson: dependency('glfw3')).
# Pin to v0.8.3 — the version ROCKNIX pairs with the SAME gamescope commit (fe78bc6) we build.
# gamescope --mangoapp is tightly coupled to the mangoapp/imgui versions; 0.8.4 + floating wrapdb
# subprojects gave a mangoapp that runs + reads its config but won't composite the overlay.
#
# patches/ = the ROCKNIX/armada Adreno+Qualcomm readers (armada release 20260621: "MangoHud shows
# previously missing GPU and power metrics"). Vanilla mangohud has NO reader for the msm/freedreno
# GPU or the Qualcomm battery, so GPU load/clock/temp + power draw render blank. They apply cleanly
# to 0.8.3 IN ORDER (0001 reworks msm detection -> msm_drm/msm_dpu; 0002 points it at the SM8550
# devfreq node 3d00000.gpu + gpuss_0_thermal hwmon; 0004 fixes the Qualcomm power_now path/scale).
# 0006 (SM8750) is intentionally omitted — we're SM8550. Patches are flat in the package dir
# (makepkg strips local source entries to basename, so a patches/ subdir wouldn't be found).
pkgname=mangohud
pkgver=0.8.3
pkgrel=2
pkgdesc="Vulkan/OpenGL FPS/frametime/CPU/GPU overlay + mangoapp for the gamescope Steam session"
arch=('aarch64')
url="https://github.com/flightlessmango/MangoHud"
license=('MIT')
depends=('gcc-libs' 'glibc' 'vulkan-icd-loader' 'libdrm' 'libcap' 'glfw' 'libglvnd' 'wayland'
         'libxkbcommon' 'libx11')
makedepends=('meson' 'ninja' 'git' 'glslang' 'vulkan-headers' 'libglvnd' 'libdrm' 'libcap'
             'glfw' 'wayland' 'wayland-protocols' 'libxkbcommon' 'libx11' 'libxrandr'
             'python-mako' 'mesa')
source=("git+https://github.com/flightlessmango/MangoHud.git#tag=v${pkgver}"
        '0001-Qualcomm-GPU-support.patch'
        '0002-SM8550-GPU.patch'
        '0003-Battery-name.patch'
        '0004-Qualcomm-battery-power-now.patch'
        '0005-RAM-name.patch')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

prepare() {
  cd MangoHud
  # Adreno/Qualcomm GPU + battery readers — order matters (0001 must precede 0002).
  for p in 0001-Qualcomm-GPU-support 0002-SM8550-GPU 0003-Battery-name \
           0004-Qualcomm-battery-power-now 0005-RAM-name; do
    echo "  applying ${p}.patch"
    git apply -p1 "${srcdir}/${p}.patch"
  done
}

build() {
  cd MangoHud
  # mangoapp=true builds the standalone overlay app gamescope --mangoapp launches.
  # NVIDIA backends disabled (no NVIDIA here; avoids nvml/xnvctrl deps).
  meson setup build --prefix=/usr --buildtype=plain \
    -Dmangoapp=true \
    -Dwith_nvml=disabled \
    -Dwith_xnvctrl=disabled
  meson compile -C build
}

package() {
  cd MangoHud
  meson install -C build --destdir "${pkgdir}"
}
