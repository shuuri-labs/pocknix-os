# gamescope (pocknix) — ROCKNIX-patched build for the RP6's rotated msm/DPU panel.
#
# Vanilla gamescope (incl. ALARM's 3.16.24) CANNOT drive the RP6 panel: the panel is
# mounted rotated (DTS rotation=<270>), so gamescope tries a DRM *plane* rotation that
# the msm DPU rejects -> "Failed to prepare 1-layer flip (Invalid argument)" forever
# (upstream issue #1883/#819). We rotate in the COMPOSITE instead — gamescope PR #2228
# (0007) folds the rotation into the existing composite's store coordinate (one pass, like
# kwin) rather than ROCKNIX's SEPARATE rotation-shader pass (0005). #2228 auto-engages when
# the scanout plane can't rotate (our msm case); pass --force-composition-rotation to force
# it. One less full-screen pass per frame = lighter present path. 0007 REPLACES 0005.
# (0005 kept in-tree, unreferenced, as a fallback.) Confirmed on ARM (AYANEO Pocket S2/SM8650).
#
# epoch=1 so this is preferred over ALARM's [extra] gamescope when both are visible.
pkgname=gamescope
epoch=1
pkgver=3.16.0.rocknix.fe78bc6
pkgrel=4
_commit=fe78bc685f247460d02c85f4b530b9de3ed07cdd
# Grant CAP_SYS_NICE to the installed binary (realtime scheduling) — see gamescope.install.
install=gamescope.install
pkgdesc="SteamOS session compositing WM — patched (composite-rotation, PR #2228, for msm/rotated panels)"
arch=('aarch64')
url="https://github.com/ValveSoftware/gamescope"
license=('BSD-2-Clause')
provides=('gamescope')
conflicts=('gamescope')
# Runtime libs (makepkg also auto-adds .so deps; these are the non-obvious ones).
depends=('wayland' 'libdrm' 'libinput' 'libxkbcommon' 'pixman' 'systemd-libs' 'libcap'
         'luajit' 'libdecor' 'libx11' 'libxext' 'libxfixes' 'libxdamage' 'libxcomposite'
         'libxrender' 'libxxf86vm' 'libxtst' 'libxi' 'libxcursor' 'libxmu' 'libxres'
         'libxcb' 'xcb-util-wm' 'seatd' 'hwdata' 'sdl2' 'pipewire' 'vulkan-icd-loader'
         'glslang' 'xorg-xwayland' 'libdisplay-info')
makedepends=('git' 'meson' 'ninja' 'cmake' 'pkgconf' 'glslang' 'vulkan-headers'
             'wayland-protocols' 'python' 'libxkbcommon' 'wayland'
             # wlroots subproject build-deps (else meson tries to build them itself):
             'xorg-xwayland' 'libdisplay-info' 'xcb-util-errors' 'xcb-util-renderutil'
             'xcb-util-image' 'xcb-util-keysyms')
source=("gamescope::git+https://github.com/ValveSoftware/gamescope.git#commit=${_commit}"
        '0001-WaylandBackend-wire-up-wl_touch-implementation.patch'
        '0004-DRMBackend-Add-GAMESCOPE_FAKE_OUTPUT_MM-env-to-set-c.patch'
        '0006-steamcompmgr-fix-gamepad-cursor-sprite-frozen-via-XTest.patch'
        '0007-composite-rotation.patch'
        '0008-Revert-mangoapp-always-send-output-frametimings.patch')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

prepare() {
  cd gamescope
  # subprojects (wlroots, libliftoff, etc.) are git submodules at this commit.
  git submodule update --init --recursive
  # ROCKNIX patch stack (same order/numbering as their package).
  patch -p1 < "${srcdir}/0001-WaylandBackend-wire-up-wl_touch-implementation.patch"
  patch -p1 < "${srcdir}/0004-DRMBackend-Add-GAMESCOPE_FAKE_OUTPUT_MM-env-to-set-c.patch"
  patch -p1 < "${srcdir}/0006-steamcompmgr-fix-gamepad-cursor-sprite-frozen-via-XTest.patch"
  # 0007 (gamescope PR #2228) REPLACES 0005's rotation shader with composite-rotation.
  patch -p1 < "${srcdir}/0007-composite-rotation.patch"
  # 0008 reverts upstream e572411d: nudge mangoapp at game COMMIT (pre-composite, like
  # ROCKNIX's older gamescope) so the overlay redraw coalesces into the same composite
  # instead of forcing an extra ~3.5ms rotated pass, and restore real (non-vblank-quantized)
  # frametimes to the overlay readout. Pairs with mangohud's 0006 pacing fix. Measured:
  # docs/archive/gamescope-fps-investigation.md "GPU-side session (2026-07-02)".
  patch -p1 < "${srcdir}/0008-Revert-mangoapp-always-send-output-frametimings.patch"
}

build() {
  cd gamescope
  # The pinned gamescope/wlroots build with -Werror, but ALARM's libs are newer than
  # upstream CI built against (e.g. newer libinput adds enum values -> -Werror=switch).
  # Disable -Werror wholesale rather than chase each version-skew warning. CFLAGS
  # propagate into the subprojects (wlroots etc.), and being last they override -Werror.
  export CFLAGS+=" -Wno-error" CXXFLAGS+=" -Wno-error"
  # CPU tuning = ROCKNIX's exact SM8550 userspace flags (distribution config/arch.aarch64 +
  # devices/SM8550/options): armv9-a + their feature set (SVE off), tuned for the X3 prime,
  # -mno-outline-atomics per their arch config. Appended last so -march/-mtune override
  # ALARM's generic armv8-a defaults; propagates into wlroots/libliftoff subprojects too.
  local _rocknix_tune="-march=armv9-a+fp16+crypto+i8mm+bf16+memtag+sm4+sha3+nosve+nosve2 -mtune=cortex-x3 -mno-outline-atomics"
  export CFLAGS+=" ${_rocknix_tune}" CXXFLAGS+=" ${_rocknix_tune}"
  meson setup build \
    --prefix=/usr --buildtype=release -Db_lto=false \
    -Ddrm_backend=enabled \
    -Dpipewire=enabled \
    -Denable_openvr_support=false \
    -Davif_screenshots=disabled \
    -Dbenchmark=disabled \
    -Dinput_emulation=disabled \
    -Drt_cap=enabled \
    -Dsdl2_backend=enabled
  meson compile -C build
}

package() {
  cd gamescope
  meson install -C build --destdir "${pkgdir}"
}
