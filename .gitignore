# build output
/build/*
!/build/.gitkeep

# vendored upstream (re-created by `make sync`)
/vendor/*
!/vendor/.gitkeep

# locally built packages
/packages/**/*.pkg.tar.zst
/packages/**/src/
/packages/**/pkg/

# decky plugin frontend build deps (dist/ IS committed — built on the dev Mac, needed by PKGBUILD)
/packages/pocknix-decky/pocknix-control/node_modules/

# local Claude Code settings
/.claude/

# personal learning journal + working-conventions doc — not part of the project
/learnings.md
/conventions.md
/suspend-resume-writeup.md
/suspend-resume-explainer.md

# macOS / editor cruft
.DS_Store
*.swp
__pycache__/
