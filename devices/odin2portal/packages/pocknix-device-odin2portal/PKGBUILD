# pocknix-device-odin2portal — the device-selector metapackage for the AYN Odin 2 Portal.
#
# Installs nothing itself; it exists so ONE installed package pins the device
# identity and pulls the right stack (BSP + SoC kernel + the shared pocknix
# session packages). The image build installs this, and a future pacman-repo
# update flows through the same dependency edges — build-time and update-time
# device selection are literally the same package. provides/conflicts
# 'pocknix-device' makes two devices' metapackages mutually uninstallable.
pkgname=pocknix-device-odin2portal
pkgver=1
pkgrel=1
pkgdesc="Pocknix device selector: AYN Odin 2 Portal (pulls the Odin 2 stack)"
arch=('any')
url="https://github.com/shuuri-labs/pocknix-os"
license=('GPL2')
depends=('pocknix-bsp-odin2portal' 'linux-pocknix-sm8550'
         'pocknix-steam' 'pocknix-desktop' 'pocknix-emulation'
         'pocknix-decky' 'pocknix-sdcard-automount')
provides=('pocknix-device')
conflicts=('pocknix-device')

package() {
  :
}
