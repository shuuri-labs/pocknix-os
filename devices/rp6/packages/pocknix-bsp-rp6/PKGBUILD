# pocknix-bsp-rp6 — board support for the Retroid Pocket 6 (SM8550).
# Everything RP6/SM8550-specific: the InputPlumber gamepad map, SoC suspend/cpuidle
# quirks, the audio UCM, the runtime device.conf contract, and the kernel cmdline.
# Shared BSP mechanics (sleep.d dispatcher, power-key policy, session udev rules)
# come from pocknix-bsp-common. Successor to the old single 'pocknix-bsp'.
pkgname=pocknix-bsp-rp6
pkgver=0.1.0
pkgrel=18
pkgdesc="pocknix board support: Retroid Pocket 6 (SM8550) — input map, suspend quirks, audio UCM, device.conf"
arch=('any')
url="https://github.com/shuuri-labs/pocknix-os"
license=('GPL2')
depends=('pocknix-bsp-common')
# Exactly one device BSP may be installed: every pocknix-bsp-<device> provides and
# conflicts 'pocknix-bsp', so pacman refuses a second device's BSP (the wrong-device
# guard for a shared repo). 'replaces' migrates installs of the old unified pocknix-bsp.
provides=('pocknix-bsp')
conflicts=('pocknix-bsp')
replaces=('pocknix-bsp')
optdepends=('inputplumber: gamepad -> Steam Input mapping (uses 01-rsinput-rp6.yaml)'
            'alsa-ucm-conf: base UCM (codec include sequences for the AYN-Odin2 UCM)')
# NOTE: the spurious deep-sleep wake is FIXED in the kernel — kernel/sm8550/patches/20-sm8550/
# 0502-wakeup-qcom-ipcc-remove-IRQF-NO-SUSPEND.patch (ported from ROCKNIX's SM8750/Odin 3)
# masks the IPCC mailbox during suspend so the ADSP charger firmware can't wake the SoC.
# See docs/archive/sm8550-suspend-wake-report.md.
source=('10-pocknix-deeponly.conf' '30-pocknix-cpuidle.conf'
        '01-rsinput-rp6.yaml' 'rp6-gamepad.yaml'
        'AYN-Odin2.conf' 'HiFi.conf'
        'device.conf' 'kernel-cmdline')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
  # Pin deep-only suspend (drop systemd's mem->standby->freeze fall-through; s2idle
  # can wedge on SM8550). systemd reads sleep.conf drop-ins from this vendor dir.
  install -Dm644 "${srcdir}/10-pocknix-deeponly.conf" \
    "${pkgdir}/usr/lib/systemd/sleep.conf.d/10-pocknix-deeponly.conf"
  # cpuidle quirk: disable cpu0 idle state1 (GMU issues) — ROCKNIX SM8550 096-cpuidle,
  # re-asserted every boot via systemd-tmpfiles.
  install -Dm644 "${srcdir}/30-pocknix-cpuidle.conf" \
    "${pkgdir}/usr/lib/tmpfiles.d/30-pocknix-cpuidle.conf"

  # InputPlumber composite-device config + capability_map for the RP6 RSInput gamepad
  # (the map fixes the driver's X/Y swap + d-pad; device config targets the Steam Deck pad).
  install -Dm644 "${srcdir}/01-rsinput-rp6.yaml" \
    "${pkgdir}/usr/share/inputplumber/devices/01-rsinput-rp6.yaml"
  install -Dm644 "${srcdir}/rp6-gamepad.yaml" \
    "${pkgdir}/usr/share/inputplumber/capability_maps/rp6-gamepad.yaml"

  # ALSA UCM for the RP6 sound card (reports as "AYN-Odin2"). The codec include
  # sequences (/lib, /codecs/wcd938x, /codecs/qcom-lpass) come from base alsa-ucm-conf.
  local ucm="${pkgdir}/usr/share/alsa/ucm2"
  install -Dm644 "${srcdir}/AYN-Odin2.conf" "${ucm}/AYN/Odin2/AYN-Odin2.conf"
  install -Dm644 "${srcdir}/HiFi.conf"      "${ucm}/AYN/Odin2/HiFi.conf"
  # card-match file (matched by card longname under the sm8550 driver dir)
  install -d "${ucm}/conf.d/sm8550"
  ln -sf "../../AYN/Odin2/AYN-Odin2.conf" "${ucm}/conf.d/sm8550/AYN-Odin2.conf"

  # Runtime device facts for shared session scripts (pocknix-steam, desktop-rotate).
  install -Dm644 "${srcdir}/device.conf" "${pkgdir}/usr/lib/pocknix/device.conf"

  # Kernel command line for the on-device /flash/KERNEL rebuild (pocknix-build-bootimg,
  # shipped by linux-pocknix-sm8550). The cmdline is DEVICE data (RP6 quirk params), so
  # it lives here, not in the shared SoC kernel package. build-packages.sh asserts this
  # file matches devices/rp6/profile.conf's KERNEL_CMDLINE so the two can't drift.
  install -Dm644 "${srcdir}/kernel-cmdline" "${pkgdir}/usr/lib/pocknix/kernel-cmdline"
}
