#!/bin/sh
# Post-resume PipeWire quantum bounce — ROCKNIX SM8250 wake quirk (their
# quirks/platforms/SM8250/sleep.d/post/003-audio + /usr/sbin/quantum): after
# resume the sm8250 qdsp6 audio path can come back glitched; forcing the graph
# quantum to 1023 and then back to 1024 kicks it into shape. ROCKNIX runs
# PipeWire system-wide; pocknix runs it in the deck user session (uid 1001,
# created by build-sd-image.sh), so address that session's instance. No-ops
# quietly when the session/socket isn't up (boot, SSH-only, pre-resume).
# Runs from pocknix-bsp-common's pocknix-sleep dispatcher: $1=post $2=suspend.
DECK_UID=1001
RUNDIR="/run/user/${DECK_UID}"
[ -S "${RUNDIR}/pipewire-0" ] || exit 0
runuser -u deck -- env XDG_RUNTIME_DIR="${RUNDIR}" pw-metadata -n settings 0 clock.force-quantum 1023 >/dev/null 2>&1 || exit 0
runuser -u deck -- env XDG_RUNTIME_DIR="${RUNDIR}" pw-metadata -n settings 0 clock.force-quantum 1024 >/dev/null 2>&1 || true
exit 0
