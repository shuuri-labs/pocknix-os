#!/bin/sh
# pocknix-fex-binfmt — get/set/apply the global FEX x86 binfmt handlers (on|off).
#
# DEFAULT IS ON (2026-07-24, the x86-proton work): binfmt-on was hardware-validated
# harmless for the ARM Proton path on both SoCs, and it is what makes x86 Proton + Steam
# Linux Runtime work out of the box (x86_64 ELFs — pressure-vessel, x86 Wine, native x86
# Linux games — exec transparently through FEX). The historical "binfmt breaks Proton
# compat-tool setup" is stale; ARM Proton never needed the handlers either way (its x86
# game code goes Wine->FEX internally, not via Linux binfmt).
#
# "off" remains available for debugging/troubleshooting. The choice persists across
# reboots in /var/lib/pocknix/fex-binfmt (absent = on, the shipped default) and is
# applied live: systemd-binfmt registers the handlers, on/off only flips their enable
# bit. `apply` re-asserts the persisted choice onto /proc and is called by
# pocknix-fex-binfmt.service at boot AND by the 90-pocknix-fex-binfmt pacman hook after
# anything re-registers binfmt.d entries (a fex-emu upgrade re-enables the handlers via
# systemd's own hook — the apply hook re-imposes an "off" choice immediately instead of
# leaking until reboot).
#
#   pocknix-fex-binfmt          # print the current LIVE state
#   pocknix-fex-binfmt on|off   # set + persist + apply (root)
#   pocknix-fex-binfmt apply    # re-assert the persisted choice (root; boot/hook use)
MODE_FILE=/var/lib/pocknix/fex-binfmt
DEFAULT=on

live_state() {
  head -1 /proc/sys/fs/binfmt_misc/FEX-x86_64 2>/dev/null | grep -q enabled && echo on || echo off
}

wanted_state() {
  m="$(cat "${MODE_FILE}" 2>/dev/null)"
  case "${m}" in on|off) echo "${m}" ;; *) echo "${DEFAULT}" ;; esac
}

apply_state() {
  v=0; [ "$(wanted_state)" = on ] && v=1
  for h in FEX-x86_64 FEX-x86; do
    echo "${v}" > "/proc/sys/fs/binfmt_misc/${h}" 2>/dev/null
  done
}

case "${1:-}" in
  "")
    live_state
    ;;
  apply)
    apply_state
    ;;
  on|off)
    mkdir -p "$(dirname "${MODE_FILE}")" 2>/dev/null
    if ! printf '%s\n' "${1}" > "${MODE_FILE}" 2>/dev/null; then
      echo "pocknix-fex-binfmt: cannot write ${MODE_FILE} (run as root)" >&2
      exit 1
    fi
    apply_state
    if [ "$(live_state)" != "${1}" ]; then
      echo "pocknix-fex-binfmt: cannot flip /proc/sys/fs/binfmt_misc/FEX-* (run as root; handlers registered?)" >&2
      exit 1
    fi
    echo "fex binfmt: ${1}"
    ;;
  *)
    echo "usage: pocknix-fex-binfmt [on|off|apply]" >&2
    exit 2
    ;;
esac
