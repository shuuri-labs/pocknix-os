#!/bin/sh
# pocknix-usbgadget — expose the RP6 over USB-C as a CDC-NCM network device so you
# can `ssh root@10.66.0.1` from your computer (no keyboard needed). Adapted from
# ROCKNIX's usbgadget (GPL). Connect USB-C to your computer BEFORE powering on so
# the UDC is present at boot.
#
# On the host side the device appears as a USB ethernet interface. macOS: set that
# interface to IP 10.66.0.2 / mask 255.255.255.0 (manually), then ssh root@10.66.0.1.
set -e

G=/sys/kernel/config/usb_gadget/pocknix
IP=10.66.0.1
PREFIX=24

modprobe libcomposite 2>/dev/null || true
mountpoint -q /sys/kernel/config || mount -t configfs none /sys/kernel/config 2>/dev/null || true

[ -d "$G" ] && exit 0   # already configured

mkdir -p "$G"
echo 0x1d6b > "$G/idVendor"        # Linux Foundation
echo 0x0104 > "$G/idProduct"       # Multifunction Composite Gadget
echo 0x0200 > "$G/bcdUSB"
mkdir -p "$G/strings/0x409"
echo "$(cut -c1-12 /etc/machine-id 2>/dev/null || echo 0123456789ab)" > "$G/strings/0x409/serialnumber"
echo "pocknix"          > "$G/strings/0x409/manufacturer"
echo "Retroid Pocket 6" > "$G/strings/0x409/product"
mkdir -p "$G/configs/c.1/strings/0x409"
echo "CDC"  > "$G/configs/c.1/strings/0x409/configuration"
echo 0xC0   > "$G/configs/c.1/bmAttributes"
echo 0xfa   > "$G/configs/c.1/MaxPower"
mkdir -p "$G/functions/ncm.usb0"
ln -sf "$G/functions/ncm.usb0" "$G/configs/c.1/"

# Wait for a UDC (only present in device mode, i.e. plugged into a host).
udc=""
i=0
while [ "$i" -lt 20 ]; do
  udc=$(ls /sys/class/udc 2>/dev/null | head -n1)
  [ -n "$udc" ] && break
  i=$((i+1)); sleep 0.5
done
if [ -z "$udc" ]; then
  echo "pocknix-usbgadget: no UDC found — connect USB-C to a host before boot" >&2
  exit 0
fi
echo "$udc" > "$G/UDC"

iface=$(cat "$G/functions/ncm.usb0/ifname")
ip addr add "$IP/$PREFIX" dev "$iface" 2>/dev/null || true
ip link set "$iface" up
echo "pocknix-usbgadget: up on ${iface} as ${IP}/${PREFIX}"
