#!/bin/sh
# pocknix-perfmode — manual A/B perf profiles for benchmarking. This is a TESTING helper,
# not a permanent config: it flips the CPU governor + scheduler + CPU affinity at runtime.
# GPU is deliberately left untouched.
#
#   rocknix : performance governor + stock EEVDF (LAVD off) + game pinned to FAST cores 3-7.
#             ROCKNIX's SM8550 recipe, with the corrected 0-2(little)/3-7(A7xx+X3) split
#             from ROCKNIX PR #2930 (NOT the stale 0-4/5-7 in our vendored snapshot).
#   lavd    : schedutil governor + scx_lavd --performance + no affinity (LAVD places freely).
#   default : restore the boot default — schedutil + pocknix-lavd.service (autopilot), unpinned.
#   status  : print current governor / scheduler / nothing else.
#
# Affinity note: 'rocknix' best-effort re-pins the ALREADY-RUNNING game tree to 3-7 (and 'lavd'
# releases it to 0-7). For a pristine affinity test, switch mode and then relaunch the game.

FAST=3-7
ALL=0-7
TRANSIENT=lavd-ab          # transient scx_lavd --performance unit this script manages
GAME_RE='gamescope|steamwebhelper|reaper|pressure-vessel|FEX|[s]team'

gov() { for g in /sys/devices/system/cpu/cpufreq/policy*/scaling_governor; do echo "$1" > "$g"; done; }

stop_lavd() {
  systemctl stop pocknix-lavd.service 2>/dev/null || true   # boot autopilot service
  systemctl stop "${TRANSIENT}.service" 2>/dev/null || true # our transient --performance one
  i=0; while [ -e /sys/kernel/sched_ext/root/ops ] && [ "$i" -lt 10 ]; do sleep 0.3; i=$((i+1)); done
}

pin() {  # $1 = cpu list; best-effort affinity over the running game process tree
  for pid in $(pgrep -f "$GAME_RE" 2>/dev/null); do taskset -acp "$1" "$pid" >/dev/null 2>&1 || true; done
}

case "$1" in
  rocknix)
    stop_lavd; gov performance; pin "$FAST"
    echo "[rocknix] performance governor + EEVDF (LAVD off) + game pinned to ${FAST}" ;;
  lavd)
    stop_lavd; gov schedutil; pin "$ALL"
    systemd-run --unit="${TRANSIENT}" --collect /usr/bin/scx_lavd --performance >/dev/null
    echo "[lavd] schedutil + scx_lavd --performance + no affinity (0-7)" ;;
  default)
    systemctl stop "${TRANSIENT}.service" 2>/dev/null || true
    gov schedutil; pin "$ALL"; systemctl start pocknix-lavd.service
    echo "[default] schedutil + pocknix-lavd autopilot (boot default)" ;;
  status)
    echo "governor : $(cat /sys/devices/system/cpu/cpufreq/policy0/scaling_governor) / $(cat /sys/devices/system/cpu/cpufreq/policy4/scaling_governor) / $(cat /sys/devices/system/cpu/cpufreq/policy7/scaling_governor)  (little/mid/prime)"
    echo "scheduler: $(cat /sys/kernel/sched_ext/root/ops 2>/dev/null || echo 'EEVDF (no sched_ext)')" ;;
  *)
    echo "usage: $0 {rocknix|lavd|default|status}" >&2; exit 1 ;;
esac
