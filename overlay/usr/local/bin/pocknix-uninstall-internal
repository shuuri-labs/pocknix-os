#!/bin/bash
# pocknix-uninstall-internal — reverse pocknix-install-internal.
#
# Two stages, because you CANNOT repartition the disk your root is mounted from:
#
#   Stage 1 (run FROM the internal install):  pocknix-uninstall-internal --disable-boot
#     Removes ONLY the internal ROCKNIX boot FAT (it is not the root, so it's safe to drop while
#     running). After a reboot the ABL can no longer boot internal, so the device boots the SD.
#     (Equivalent to the ABL menu's "Uninstall ROCKNIX" — our boot partition is GPT-named ROCKNIX.)
#
#   Stage 2 (run FROM the SD, after rebooting to it):  pocknix-uninstall-internal
#     Removes the leftover POCKNIX_ROOT and grows Android userdata back to fill the disk. Refuses to
#     run if / is on the target device (i.e. don't run the full uninstall from internal).
#
#   Re-enable (run FROM the SD, if you ONLY --disable-boot'd and want internal pocknix back):
#     pocknix-uninstall-internal --enable-boot
#     Recreates the boot FAT in the gap --disable-boot left (POCKNIX_ROOT is untouched) and
#     regenerates /flash/KERNEL from the internal rootfs's OWN kernel via pocknix-build-bootimg —
#     NO 27 GB re-clone, and NOT the SD's KERNEL (which may be ROCKNIX's, wrong for our rootfs).
#
# Never touches abl/xbl/modem/persist/super — only ROCKNIX, POCKNIX_ROOT, and userdata.
set -euo pipefail

# Device facts (internal disk + boot contract) come from the BSP's device.conf; the
# defaults equal the RP6/SM8550 values (see pocknix-install-internal).
[ -r /usr/lib/pocknix/device.conf ] && . /usr/lib/pocknix/device.conf
[ -r /etc/pocknix/device.conf ] && . /etc/pocknix/device.conf

# Boot style: the full uninstall (delete the pocknix partitions, re-grow userdata)
# and --disable-boot (delete the boot FAT — no bootaa64.efi/KERNEL = nothing to
# chainload) are style-agnostic. Only --enable-boot's KERNEL regeneration is
# qcom-abl-specific (pocknix-build-bootimg); on arm-efi it refuses below.
BOOT_STYLE="${POCKNIX_BOOT_STYLE:-qcom-abl}"
case "$BOOT_STYLE" in
  qcom-abl|arm-efi) ;;
  *) echo "pocknix-uninstall-internal: unknown boot style '${BOOT_STYLE}'" >&2; exit 1 ;;
esac

DEVICE="${DEVICE:-${POCKNIX_INTERNAL_DISK:-/dev/sda}}"
BOOT_NAME="${POCKNIX_BOOT_GPT_NAME:-ROCKNIX}"     # GPT name of the boot FAT  (pocknix-install-internal)
ROOT_NAME="${POCKNIX_ROOT_LABEL:-POCKNIX_ROOT}"   # GPT name of the ext4 root
DISABLE_BOOT=0 ; ENABLE_BOOT=0 ; DRY_RUN=0 ; ASSUME_YES=0

say()  { echo -e "[\033[1;34mpocknix-uninstall\033[0m] $*"; }
die()  { echo -e "[\033[1;31mERROR\033[0m] $*" >&2; exit 1; }
run()  { if [ "$DRY_RUN" = 1 ]; then echo "  + $*"; else "$@"; fi; }

while [ $# -gt 0 ]; do
  case "$1" in
    --disable-boot) DISABLE_BOOT=1 ;;
    --enable-boot)  ENABLE_BOOT=1 ;;
    --dry-run)      DRY_RUN=1 ;;
    --yes|-y)       ASSUME_YES=1 ;;
    --device)       DEVICE="$2"; shift ;;
    *) die "unknown arg: $1 (use --disable-boot | --enable-boot | --dry-run | --yes | --device DEV)" ;;
  esac
  shift
done

[ "$(id -u)" = 0 ] || die "must run as root"
for t in parted blkid lsblk findmnt wipefs; do command -v "$t" >/dev/null 2>&1 || die "missing tool: $t"; done
[ -b "$DEVICE" ] || die "$DEVICE is not a block device"

# partition lookup helper: echo the partition NUMBER for a GPT name (empty if absent)
partnum() { parted -m -s "$DEVICE" print 2>/dev/null | awk -F: -v n="$1" '$6==n{print $1}'; }
partdev() { case "$DEVICE" in *[0-9]) echo "${DEVICE}p$1" ;; *) echo "${DEVICE}$1" ;; esac; }

BOOT_NUM="$(partnum "$BOOT_NAME" || true)"
ROOT_NUM="$(partnum "$ROOT_NAME" || true)"

# ---------------------------------------------------------------------------------------------------
# Re-enable internal boot: recreate the boot FAT --disable-boot removed + regenerate KERNEL from the
# (intact) internal POCKNIX_ROOT. Run FROM THE SD. No re-clone. MUST be before the Stage-2 fallthrough.
# ---------------------------------------------------------------------------------------------------
if [ "$ENABLE_BOOT" = 1 ]; then
  [ "$BOOT_STYLE" = "qcom-abl" ] \
    || die "--enable-boot is qcom-abl only (its KERNEL regeneration uses pocknix-build-bootimg). On ${BOOT_STYLE}, re-run pocknix-install-internal instead."
  [ -z "$BOOT_NUM" ] || die "a '$BOOT_NAME' partition already exists on $DEVICE — boot isn't disabled (nothing to do)."
  [ -n "$ROOT_NUM" ] || die "no '$ROOT_NAME' on $DEVICE — nothing to re-enable; do a full pocknix-install-internal."
  root_src="$(findmnt -no SOURCE / || true)"
  case "$root_src" in "$DEVICE"|"$DEVICE"p[0-9]*|"$DEVICE"[0-9]*) die "/ is on $DEVICE — boot to the SD first, then run --enable-boot." ;; esac
  for t in mkfs.vfat blockdev partprobe; do command -v "$t" >/dev/null 2>&1 || die "missing tool: $t"; done

  # The boot FAT was deleted from the gap between userdata and POCKNIX_ROOT — recreate it there.
  ud_num="$(partnum userdata)"; [ -n "$ud_num" ] || die "no 'userdata' partition on $DEVICE"
  span_mib() { parted -m -s "$DEVICE" unit MiB print | awk -F: -v n="$1" '$1==n{gsub("MiB","");print $2" "$3}'; }
  UD_END="$(span_mib "$ud_num"   | awk '{printf "%d",$2}')"
  ROOT_START="$(span_mib "$ROOT_NUM" | awk '{printf "%d",$1}')"
  [ "$ROOT_START" -gt "$UD_END" ] || die "no free gap between userdata (${UD_END}MiB) and $ROOT_NAME (${ROOT_START}MiB)."

  say "Re-enable internal boot on $DEVICE:"
  say "  recreate '$BOOT_NAME' FAT in the gap ${UD_END}..${ROOT_START} MiB ($((ROOT_START-UD_END)) MiB)"
  say "  regenerate KERNEL from the intact internal $ROOT_NAME (its OWN kernel, not the SD's)"
  if [ "$ASSUME_YES" != 1 ] && [ "$DRY_RUN" != 1 ]; then
    read -rp "Proceed? [y/N]: " c; [[ $c =~ ^[Yy]$ ]] || die "aborted"
  fi

  run parted -a optimal -s "$DEVICE" mkpart primary fat32 "${UD_END}MiB" "${ROOT_START}MiB"
  if [ "$DRY_RUN" = 1 ]; then
    say "(dry-run) would: name it '$BOOT_NAME', mkfs.vfat -F 32 -S <sectorsize> -s 1 -n $BOOT_NAME, then chroot $ROOT_NAME pocknix-build-bootimg"
    exit 0
  fi
  partprobe "$DEVICE" 2>/dev/null || true; sleep 1
  NEW="$(partnum "$BOOT_NAME" || true)"
  [ -n "$NEW" ] || NEW="$(parted -m -s "$DEVICE" unit MiB print | awk -F: -v s="$UD_END" '$1 ~ /^[0-9]+$/ {st=$2; gsub("MiB","",st); if (int(st)==s) print $1}' | head -1)"
  [ -n "$NEW" ] || die "could not locate the recreated boot partition"
  parted -s "$DEVICE" name "$NEW" "$BOOT_NAME"
  partprobe "$DEVICE" 2>/dev/null || true; sleep 1
  bdev="$(partdev "$NEW")"; ss="$(blockdev --getss "$bdev")"
  say "Formatting $bdev FAT32 (-S $ss -s 1, name/label $BOOT_NAME) ..."
  mkfs.vfat -F 32 -S "$ss" -s 1 -n "$BOOT_NAME" "$bdev" >/dev/null

  # Regenerate /flash/KERNEL inside the internal rootfs (its own Image + dtbs + cmdline + mkbootimg).
  RMNT="$(mktemp -d)"; rdev="$(partdev "$ROOT_NUM")"
  cleanup_enable() { for m in dev proc sys; do umount "$RMNT/$m" 2>/dev/null || true; done
                     umount "$RMNT/flash" 2>/dev/null || true; umount "$RMNT" 2>/dev/null || true; rmdir "$RMNT" 2>/dev/null || true; }
  trap cleanup_enable EXIT
  mount "$rdev" "$RMNT"
  [ -x "$RMNT/usr/bin/pocknix-build-bootimg" ] || die "internal rootfs lacks pocknix-build-bootimg — can't regenerate KERNEL"
  mkdir -p "$RMNT/flash"; mount "$bdev" "$RMNT/flash"
  for m in dev proc sys; do mount --bind "/$m" "$RMNT/$m"; done
  say "Regenerating /flash/KERNEL (+KERNEL.md5) inside $ROOT_NAME ..."
  chroot "$RMNT" /usr/bin/pocknix-build-bootimg || die "pocknix-build-bootimg failed in chroot"
  cleanup_enable; trap - EXIT
  say "Done — internal boot re-enabled. Power off, REMOVE the SD, and boot: internal pocknix should come up."
  exit 0
fi

# ---------------------------------------------------------------------------------------------------
# Stage 1: disable internal boot (safe from the running internal system)
# ---------------------------------------------------------------------------------------------------
if [ "$DISABLE_BOOT" = 1 ]; then
  [ -n "$BOOT_NUM" ] || die "no '$BOOT_NAME' boot partition on $DEVICE — already disabled?"
  bdev="$(partdev "$BOOT_NUM")"
  say "Stage 1: removing the internal boot FAT ($bdev, '$BOOT_NAME' #$BOOT_NUM)."
  say "POCKNIX_ROOT is left intact; finish cleanup from the SD with: pocknix-uninstall-internal"
  if [ "$ASSUME_YES" != 1 ] && [ "$DRY_RUN" != 1 ]; then
    read -rp "Proceed? After reboot the device will boot the SD. [y/N]: " c; [[ $c =~ ^[Yy]$ ]] || die "aborted"
  fi
  mountpoint -q /flash && run umount /flash || true
  run parted -s "$DEVICE" rm "$BOOT_NUM"   # kernel can't re-read a busy disk; the on-disk GPT IS updated
  say "Done. The partition table is updated on disk (the running kernel keeps the old view)."
  say "Now: power off, REMOVE then RE-INSERT the SD if needed, and boot — it should come up on the SD."
  exit 0
fi

# ---------------------------------------------------------------------------------------------------
# Stage 2: full uninstall (must NOT be the disk we're booted from)
# ---------------------------------------------------------------------------------------------------
root_src="$(findmnt -no SOURCE / || true)"
case "$root_src" in
  "$DEVICE"|"$DEVICE"p[0-9]*|"$DEVICE"[0-9]*)
    die "/ is on $DEVICE — you're booted from the internal install. Run with --disable-boot first, reboot to the SD, then re-run this." ;;
esac

[ -n "$ROOT_NUM" ] || [ -n "$BOOT_NUM" ] || die "no pocknix install found on $DEVICE (no $BOOT_NAME / $ROOT_NAME)"

UD_NUM="$(partnum userdata || true)"
[ -n "$UD_NUM" ] || die "no Android 'userdata' partition on $DEVICE — refusing to guess the layout"

# userdata start + the highest end among userdata/ROCKNIX/POCKNIX_ROOT (in MiB), so we grow userdata
# back over exactly the space install took. Read boundaries in MiB.
read_mib() { parted -m -s "$DEVICE" unit MiB print | awk -F: -v n="$1" '$1==n{gsub("MiB","");print $2" "$3}'; }
UD_START="$(read_mib "$UD_NUM" | awk '{printf "%d", $1}')"
END=0
for n in "$UD_NUM" "$BOOT_NUM" "$ROOT_NUM"; do
  [ -n "$n" ] || continue
  e="$(read_mib "$n" | awk '{printf "%d", $2}')"; [ "$e" -gt "$END" ] && END="$e"
done
[ "$UD_START" -gt 0 ] && [ "$END" -gt "$UD_START" ] || die "could not compute userdata boundaries"

say "Plan on $DEVICE:"
say "  remove ${ROOT_NAME:+$ROOT_NAME #$ROOT_NUM}  ${BOOT_NAME:+$BOOT_NAME #$BOOT_NUM}"
say "  grow  userdata #$UD_NUM  ->  ${UD_START}MiB .. ${END}MiB  (reclaims the pocknix space)"
say "  Android will reformat userdata on its next boot (its contents are wiped)."
if [ "$ASSUME_YES" != 1 ] && [ "$DRY_RUN" != 1 ]; then
  read -rp "Proceed? [y/N]: " c; [[ $c =~ ^[Yy]$ ]] || die "aborted"
fi

if [ -n "$ROOT_NUM" ]; then run parted -s "$DEVICE" rm "$ROOT_NUM"; fi
BOOT_NUM="$(partnum "$BOOT_NAME" || true)"            # re-read: numbers can shift after an rm
if [ -n "$BOOT_NUM" ]; then run parted -s "$DEVICE" rm "$BOOT_NUM"; fi
UD_NUM="$(partnum userdata || true)"
run parted -s "$DEVICE" rm "$UD_NUM"
run parted -a optimal -s "$DEVICE" mkpart primary ext4 "${UD_START}MiB" "${END}MiB"

if [ "$DRY_RUN" = 1 ]; then
  say "(dry-run) would: name the new ${UD_START}MiB partition 'userdata' and wipe its fs signature"
  exit 0
fi

# locate the just-created partition by its start offset, name it userdata, wipe any stale signature
newnum="$(parted -m -s "$DEVICE" unit MiB print \
  | awk -F: -v s="$UD_START" '$1 ~ /^[0-9]+$/ { st=$2; gsub("MiB","",st); if (int(st)==s) print $1 }' | head -1)"
[ -n "$newnum" ] || die "could not locate the recreated userdata partition at ${UD_START}MiB"
parted -s "$DEVICE" name "$newnum" userdata
partprobe "$DEVICE" 2>/dev/null || true
wipefs -a "$(partdev "$newnum")" 2>/dev/null || true   # Android reformats userdata on its next boot
say "Done: userdata restored as partition #$newnum (${UD_START}–${END}MiB). Power off and boot."
say "The SD/Android now boots; reinstall a fresh pocknix later with pocknix-install-internal."
