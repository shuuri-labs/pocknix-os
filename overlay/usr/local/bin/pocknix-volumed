#!/usr/bin/env python3
# pocknix-volumed — make the RP6 volume rocker actually change volume.
#
# The rocker emits plain KEY_VOLUMEUP / KEY_VOLUMEDOWN (gpio-keys). Steam's gamepadui shows the volume
# OSD on these but doesn't change the volume — its volume action is tied to the Steam Deck controller's
# volume buttons, not generic KEY_VOLUME* (the Settings>Audio slider works because it talks to PipeWire
# directly). So we watch the keys WITHOUT grabbing them (Steam still gets them for the OSD) and call
# wpctl as the 'deck' user, whose PipeWire owns the sink. Runs as root (reads any input device).
import sys, subprocess, select
try:
    from evdev import InputDevice, list_devices, ecodes
except ImportError:
    sys.exit("pocknix-volumed: python-evdev not installed")

DECK_UID = "1001"
SINK = "@DEFAULT_AUDIO_SINK@"
STEP = "5%"

def setvol(delta):
    # runuser -> deck so wpctl reaches deck's PipeWire; -l 1.0 caps at 100%.
    subprocess.run(
        ["runuser", "-u", "deck", "--", "env", "XDG_RUNTIME_DIR=/run/user/" + DECK_UID,
         "wpctl", "set-volume", "-l", "1.0", SINK, delta],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

# Every input device that reports the volume keys (there may be more than one).
devs = []
for path in list_devices():
    try:
        d = InputDevice(path)
        keys = d.capabilities().get(ecodes.EV_KEY, [])
        if ecodes.KEY_VOLUMEUP in keys or ecodes.KEY_VOLUMEDOWN in keys:
            devs.append(d)
    except OSError:
        pass
if not devs:
    sys.exit("pocknix-volumed: no volume-key input device found")

fds = {d.fd: d for d in devs}
while True:
    r, _, _ = select.select(list(fds), [], [])
    for fd in r:
        try:
            for ev in fds[fd].read():
                if ev.type == ecodes.EV_KEY and ev.value == 1:   # key down only (one step per press)
                    if ev.code == ecodes.KEY_VOLUMEUP:
                        setvol(STEP + "+")
                    elif ev.code == ecodes.KEY_VOLUMEDOWN:
                        setvol(STEP + "-")
        except OSError:
            pass
