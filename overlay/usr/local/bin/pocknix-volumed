#!/usr/bin/env python3
# pocknix-volumed — make the RP6 volume rocker actually change volume.
#
# The rocker emits plain KEY_VOLUMEUP / KEY_VOLUMEDOWN. Steam's gamepadui shows the volume OSD on
# these but doesn't change the volume (its volume action is tied to the Steam Deck controller's
# buttons, not generic KEY_VOLUME*; the Settings>Audio slider works because it talks to PipeWire
# directly). So we watch the keys WITHOUT grabbing them (Steam still gets the OSD) and call wpctl on
# deck's PipeWire.
#
# Robustness (learned the hard way):
#  - Match the source device by CAPABILITY (it reports the volume keys), NOT by name. An earlier
#    version hardcoded name == "gpio-keys" and exited when the evdev *name* differed from the
#    interrupt name -> daemon dead -> volume keys did nothing.
#  - NEVER sys.exit: if no device is present yet, keep waiting/rescanning (the service must not die).
#  - Capability-match also opens InputPlumber's virtual keyboard, which comes and goes (e.g. our
#    suspend hook stops InputPlumber). A hung-up fd makes select() spin a CPU at 100%, so we DROP a
#    fd the moment it errors and rescan to pick up replacements. (InputPlumber only sources
#    rsinput-gamepad, not the rocker, so the virtual device never actually emits the rocker's
#    volume events -> no double-counting.)
#  - wpctl runs with a TIMEOUT so a stuck PipeWire call can never block key handling (the freeze).
import sys, os, time, select, subprocess
try:
    from evdev import InputDevice, list_devices, ecodes
except ImportError:
    sys.exit("pocknix-volumed: python-evdev not installed")

DECK_UID = "1001"
SINK = "@DEFAULT_AUDIO_SINK@"
STEP = "5%"
RESCAN_SECS = 5      # re-enumerate devices that (dis)appeared
WPCTL_TIMEOUT = 2    # never let a stuck wpctl block the key loop

def setvol(delta):
    # Root can open deck's PipeWire socket directly (no runuser/PAM overhead). Bounded by a timeout
    # so a hung call can't freeze key handling.
    env = dict(os.environ, XDG_RUNTIME_DIR="/run/user/" + DECK_UID)
    try:
        subprocess.run(["wpctl", "set-volume", "-l", "1.0", SINK, delta],
                       env=env, timeout=WPCTL_TIMEOUT,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except (subprocess.TimeoutExpired, OSError):
        pass

def has_volume_keys(dev):
    keys = dev.capabilities().get(ecodes.EV_KEY, [])
    return ecodes.KEY_VOLUMEUP in keys or ecodes.KEY_VOLUMEDOWN in keys

def scan(known_paths):
    # Open any NEW device that reports the volume keys (keyed by path so we don't reopen held ones).
    found = {}
    for path in list_devices():
        if path in known_paths:
            continue
        try:
            dev = InputDevice(path)
        except OSError:
            continue
        if has_volume_keys(dev):
            found[path] = dev
        else:
            dev.close()
    return found

devs = {}            # path -> InputDevice
last_scan = 0.0
while True:
    now = time.monotonic()
    if now - last_scan >= RESCAN_SECS:
        devs.update(scan(set(devs)))
        last_scan = now
    if not devs:
        time.sleep(1)            # nothing to watch yet — wait, never exit
        continue

    by_fd = {dev.fd: (path, dev) for path, dev in devs.items()}
    try:
        ready, _, _ = select.select(list(by_fd), [], [], RESCAN_SECS)
    except OSError:
        # a watched fd went invalid out from under select(); drop all and rescan clean
        for dev in devs.values():
            try: dev.close()
            except OSError: pass
        devs.clear()
        last_scan = 0.0
        continue

    for fd in ready:
        path, dev = by_fd[fd]
        try:
            for ev in dev.read():
                if ev.type == ecodes.EV_KEY and ev.value == 1:   # key down only (one step per press)
                    if ev.code == ecodes.KEY_VOLUMEUP:
                        setvol(STEP + "+")
                    elif ev.code == ecodes.KEY_VOLUMEDOWN:
                        setvol(STEP + "-")
        except OSError:
            # device went away (e.g. InputPlumber tore down its virtual keyboard). Drop the dead fd
            # NOW so select() stops returning it instantly — that was the 100% busy-loop.
            try: dev.close()
            except OSError: pass
            devs.pop(path, None)
